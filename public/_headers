# TEMPORARY: Force all browsers to unregister broken service workers.
# Remove after 2026-04-10.
/
  Clear-Site-Data: "storage"
/index.html
  Clear-Site-Data: "storage"
/library
  Clear-Site-Data: "storage"
/library/*
  Clear-Site-Data: "storage"
/docs
  Clear-Site-Data: "storage"
/docs/*
  Clear-Site-Data: "storage"

# Service worker should never be cached
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate

# Workbox chunks also shouldn't be cached long
/workbox-*.js
  Cache-Control: no-cache, no-store, must-revalidate

# Library pages - no caching
/library/*
  Cache-Control: no-cache, no-store, must-revalidate
  CDN-Cache-Control: no-cache

# Static assets - long cache (content-hashed filenames)
/_astro/*
  Cache-Control: public, max-age=31536000, immutable
