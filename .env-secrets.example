# SifterSearch Secrets Configuration
# Copy this to .env-secrets and fill in your actual secret values
# NEVER commit .env-secrets to version control!

# ==============================
# Database Secrets
# ==============================
TURSO_AUTH_TOKEN=your-turso-auth-token

# ==============================
# Authentication Secrets
# ==============================
JWT_ACCESS_SECRET=generate-a-64-char-random-string-here
JWT_REFRESH_SECRET=generate-another-64-char-random-string-here
CLERK_SECRET_KEY=sk_test_your-clerk-secret-key

# ==============================
# AI Provider API Keys
# ==============================
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ==============================
# Storage Secrets (Cloudflare R2)
# ==============================
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# R2_BUCKET_NAME=siftersearch
# R2_PUBLIC_URL=https://siftersearch.r2.dev

# Scaleway (fallback)
SCALEWAY_ACCESS_KEY=your-scaleway-access-key
SCALEWAY_SECRET_KEY=your-scaleway-secret-key

# ==============================
# Stripe (API Billing)
# ==============================
STRIPE_SECRET_KEY_LIVE=sk_live_...
STRIPE_PUBLISHABLE_KEY_LIVE=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_API_METERED_PRICE_ID=price_...

# ==============================
# Email/SMTP Secrets
# ==============================
BREVO_API_KEY=your-brevo-api-key
RESEND_API_KEY=re_your-resend-api-key
SENDGRID_API_KEY=SG.your-sendgrid-api-key

# ==============================
# Voice/Ultravox
# ==============================
ULTRAVOX_API_KEY=your-ultravox-api-key
