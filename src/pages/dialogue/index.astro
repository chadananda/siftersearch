---
// Dialog index — live listing from API (published_conversations table).
// No prerender — content is live, no rebuild needed to add/update dialogs.
import Layout from '../../layouts/Layout.astro';
import LiquidBackground from '../../components/LiquidBackground.svelte';
import NavBar from '../../components/common/NavBar.svelte';
import { smartQuotes as sq } from '../../lib/smart-quotes.js';
import { cardUrl } from '../../lib/imagekit.js';

// Strip inline markdown (bold, italic, code) for plain-text card display
const stripMd = (s: string) => sq(
  (s || '').replace(/\*\*([^*]+)\*\*/g, '$1').replace(/\*([^*]+)\*/g, '$1')
    .replace(/__([^_]+)__/g, '$1').replace(/_([^_]+)_/g, '$1')
    .replace(/`([^`]+)`/g, '$1')
);

const API_BASE = import.meta.env.PUBLIC_API_URL || 'https://api.siftersearch.com';
const res = await fetch(`${API_BASE}/api/v1/dialogs`);
const { dialogs = [] } = res.ok ? await res.json() : {};

// Normalize API rows — tags_json is a JSON string
const dialogs_norm = dialogs.map(d => ({
  ...d,
  tags: JSON.parse(d.tags_json || '[]'),
}));

const TOPIC_LABELS: Record<string, string> = {
  'theology': 'Theology',
  'ethics': 'Ethics',
  'social-order': 'Social Order',
  'politics': 'Politics',
  'history': 'History',
  'comparative-religion': 'Comparative Religion',
  'mysticism': 'Mysticism',
  'practice': 'Practice',
  'modern-challenges': 'Modern Challenges',
  'word-meaning': 'Word & Meaning',
  'metaphysics': 'Metaphysics',
  'philosophy': 'Philosophy',
};

const byTopic = new Map<string, typeof dialogs_norm>();
for (const d of dialogs_norm) {
  const arr = byTopic.get(d.topic) ?? [];
  arr.push(d);
  byTopic.set(d.topic, arr);
}

const tagCounts = new Map<string, number>();
for (const d of dialogs_norm) {
  for (const t of d.tags) tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1);
}
const tagList = Array.from(tagCounts.entries())
  .filter(([, n]) => n >= 2)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 40);
const multiTagSet = new Set(tagList.map(([t]) => t));

const totalDialogs = dialogs_norm.length;
const totalRounds = dialogs_norm.reduce((s, d) => s + (d.rounds_count || 0), 0);
const avgScore = dialogs_norm.length
  ? Math.round(dialogs_norm.reduce((s, d) => s + (d.score || 0), 0) / dialogs_norm.length)
  : 0;

const description = `Long-form dialogues exploring ${totalDialogs} deep questions in Bahá'í teachings, comparative theology, and philosophy. Each conversation goes ten or more rounds — questioning assumptions, examining word definitions across centuries, and weighing actual textual evidence.`;
---

<Layout title="Dialog — Deep Conversations on Faith, Meaning, and Text" description={description}>
  <LiquidBackground client:only="svelte" />
  <NavBar currentPage="dialog" client:load />

  <main class="dialog-index">
    <header class="hero">
      <div class="hero-decoration" aria-hidden="true">
        <svg viewBox="0 0 600 200" preserveAspectRatio="xMidYMid slice">
          <!-- Hand-drawn watercolor wash, blue-shaded -->
          <defs>
            <radialGradient id="wash1" cx="20%" cy="50%" r="60%">
              <stop offset="0%" stop-color="rgba(56,114,184,0.55)" />
              <stop offset="100%" stop-color="rgba(56,114,184,0)" />
            </radialGradient>
            <radialGradient id="wash2" cx="80%" cy="40%" r="50%">
              <stop offset="0%" stop-color="rgba(108,156,209,0.45)" />
              <stop offset="100%" stop-color="rgba(108,156,209,0)" />
            </radialGradient>
            <radialGradient id="wash3" cx="55%" cy="80%" r="45%">
              <stop offset="0%" stop-color="rgba(31,82,148,0.5)" />
              <stop offset="100%" stop-color="rgba(31,82,148,0)" />
            </radialGradient>
          </defs>
          <rect x="0" y="0" width="600" height="200" fill="url(#wash1)" />
          <rect x="0" y="0" width="600" height="200" fill="url(#wash2)" />
          <rect x="0" y="0" width="600" height="200" fill="url(#wash3)" />
          <!-- Stylized brush strokes -->
          <path d="M 30 130 Q 150 80 280 120 T 570 100" stroke="rgba(20,52,98,0.4)" stroke-width="2" fill="none" stroke-linecap="round" />
          <path d="M 50 160 Q 200 130 380 150 T 580 145" stroke="rgba(20,52,98,0.3)" stroke-width="1.5" fill="none" stroke-linecap="round" />
        </svg>
      </div>
      <h1>Dialogues with the Ocean</h1>
      <p class="hero-tag">Meaningful interfaith conversations with the Ocean library. <a class="meta-link" href="/dialogue/assessment">How these are assessed →</a></p>
      <div class="hero-stats">
        <div><strong>{totalDialogs}</strong><span>conversations</span></div>
        <div><strong>{totalRounds}</strong><span>rounds of follow-up</span></div>
        <div><strong>{avgScore}<small>%</small></strong><span>average quality score</span></div>
      </div>
    </header>

    {tagList.length > 0 && (
      <section class="tag-cloud">
        <h2 class="section-label">Tags</h2>
        <div class="tags">
          {tagList.map(([tag, count]) => (
            <a class="tag-pill" href={`/dialogue/tag/${encodeURIComponent(tag)}/`} data-count={count}>
              <span class="tag-text">{tag}</span>
              <span class="tag-count">{count}</span>
            </a>
          ))}
        </div>
      </section>
    )}

    <section class="recent-block">
      <header class="topic-header">
        <h2>Most recent</h2>
        <span class="topic-count">{dialogs_norm.length}</span>
      </header>
      <div class="cards">
        {dialogs_norm.map(d => (
            <article class="card" data-featured={d.featured}>
              {d.hero_image && (
                <div class="card-image">
                  <img src={cardUrl(d.hero_image)} alt={d.title} loading="lazy" />
                </div>
              )}
              {!d.hero_image && (
                <div class="card-image card-image-placeholder" aria-hidden="true">
                  <svg viewBox="0 0 400 240" preserveAspectRatio="xMidYMid slice">
                    <defs>
                      <radialGradient id={`p-${d.slug}-1`} cx="30%" cy="40%" r="55%">
                        <stop offset="0%" stop-color="rgba(56,114,184,0.6)" />
                        <stop offset="100%" stop-color="rgba(20,52,98,0.1)" />
                      </radialGradient>
                      <radialGradient id={`p-${d.slug}-2`} cx="75%" cy="65%" r="45%">
                        <stop offset="0%" stop-color="rgba(140,180,220,0.5)" />
                        <stop offset="100%" stop-color="rgba(20,52,98,0)" />
                      </radialGradient>
                    </defs>
                    <rect width="400" height="240" fill="rgba(20,52,98,0.4)" />
                    <rect width="400" height="240" fill={`url(#p-${d.slug}-1)`} />
                    <rect width="400" height="240" fill={`url(#p-${d.slug}-2)`} />
                  </svg>
                </div>
              )}
              <div class="card-body">
                <a class="card-topic" href={`/dialogue/category/${d.topic}/`}>{TOPIC_LABELS[d.topic] ?? d.topic}</a>
                <h3><a class="card-title-link" href={`/dialogue/${d.slug}/`}>{sq(d.title)}</a></h3>
                <p class="card-summary">{stripMd(d.description)}</p>
                <div class="card-meta">
                  {d.score > 0 && (
                    <span class="score" data-score={d.score}>{d.score}%</span>
                  )}
                  <span class="rounds">{d.rounds_count} rounds</span>
                  {d.tags.slice(0, 3).map(t => (
                    multiTagSet.has(t)
                      ? <a class="card-tag link" href={`/dialogue/tag/${encodeURIComponent(t)}/`}>{t}</a>
                      : <span class="card-tag">{t}</span>
                  ))}
                </div>
              </div>
            </article>
        ))}
      </div>
    </section>

    {dialogs_norm.length === 0 && (
      <section class="empty">
        <p>The first dialogues are being prepared. Check back shortly.</p>
      </section>
    )}
  </main>
</Layout>

<style>
  .dialog-index {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1.5rem 6rem;
    color: var(--text-primary);
  }

  .hero {
    position: relative;
    padding: 5rem 2rem 4rem;
    margin-bottom: 3rem;
    border-radius: 24px;
    overflow: hidden;
    background: linear-gradient(135deg, rgba(20,52,98,0.4) 0%, rgba(56,114,184,0.2) 100%);
    border: 1px solid rgba(140,180,220,0.15);
  }

  .hero-decoration {
    position: absolute;
    inset: 0;
    z-index: 0;
    opacity: 0.85;
  }
  .hero-decoration svg { width: 100%; height: 100%; }

  .hero h1 {
    position: relative;
    font-family: 'Libre Caslon Text', serif;
    font-size: clamp(3rem, 7vw, 5.5rem);
    font-weight: 400;
    margin: 0;
    letter-spacing: -0.02em;
    line-height: 1;
    color: var(--text-primary);
    text-shadow: 0 2px 12px rgba(0,0,0,0.25);
  }

  .hero-tag {
    position: relative;
    font-family: 'Libre Caslon Text', serif;
    font-style: italic;
    font-size: 1.25rem;
    color: var(--text-secondary);
    margin: 1rem 0 2.5rem;
    max-width: 38rem;
  }
  .meta-link {
    font-style: normal;
    font-size: 0.85rem;
    color: var(--accent);
    text-decoration: none;
    margin-left: 0.5rem;
    border-bottom: 1px dotted rgba(186, 160, 82, 0.4);
    white-space: nowrap;
  }
  .meta-link:hover { color: rgb(218, 188, 110); }

  .hero-stats {
    position: relative;
    display: flex;
    gap: 3rem;
    flex-wrap: wrap;
  }

  .hero-stats > div {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .hero-stats strong {
    font-family: 'Libre Caslon Text', serif;
    font-size: 2.5rem;
    font-weight: 400;
    color: var(--accent);
    line-height: 1;
  }

  .hero-stats strong small {
    font-size: 1.25rem;
    color: var(--text-secondary);
    margin-left: 0.1em;
  }

  .hero-stats span {
    font-size: 0.875rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .section-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--text-muted);
    margin: 0 0 1rem;
    font-weight: 600;
  }

  .tag-cloud {
    margin-bottom: 4rem;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.9rem;
    border-radius: 999px;
    background: rgba(56,114,184,0.12);
    border: 1px solid rgba(56,114,184,0.25);
    color: var(--text-secondary);
    text-decoration: none;
    font-size: 0.875rem;
    transition: all 0.2s ease;
  }

  .tag-pill:hover {
    background: rgba(56,114,184,0.25);
    color: var(--text-primary);
    transform: translateY(-1px);
  }

  .tag-count {
    font-size: 0.75rem;
    opacity: 0.6;
    background: rgba(140,180,220,0.15);
    padding: 0.05rem 0.45rem;
    border-radius: 999px;
  }

  .topic-block {
    margin-bottom: 4rem;
  }

  .topic-header {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 1.5rem;
    border-bottom: 1px solid rgba(140,180,220,0.1);
    padding-bottom: 0.75rem;
  }

  .topic-header h2 {
    font-family: 'Libre Caslon Text', serif;
    font-size: 1.75rem;
    font-weight: 400;
    margin: 0;
    color: var(--text-primary);
  }

  .topic-count {
    font-size: 0.875rem;
    color: var(--text-muted);
    background: rgba(140,180,220,0.1);
    padding: 0.15rem 0.7rem;
    border-radius: 999px;
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }

  .card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: rgba(20,52,98,0.18);
    border: 1px solid rgba(140,180,220,0.12);
    border-radius: 16px;
    overflow: hidden;
    color: inherit;
    transition: all 0.25s ease;
  }

  /* Stretched-link pattern. Outer card is an <article> (no nested <a>);
     the title link's ::after covers the whole card, making it clickable
     while topic/tag links remain real, separately-clickable anchors. */
  .card-title-link {
    color: var(--text-primary);
    text-decoration: none;
  }
  .card-title-link::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 1;
  }
  .card-topic,
  a.card-tag.link {
    position: relative;
    z-index: 2;
  }

  .card:hover {
    transform: translateY(-4px);
    border-color: rgba(140,180,220,0.35);
    box-shadow: 0 12px 32px rgba(20,52,98,0.4);
  }

  .card[data-featured="true"] {
    border-color: rgba(186,160,82,0.4);
    background: linear-gradient(135deg, rgba(186,160,82,0.08) 0%, rgba(20,52,98,0.18) 60%);
  }

  .card-image {
    aspect-ratio: 5 / 3;
    overflow: hidden;
    background: rgba(20,52,98,0.3);
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .card-image-placeholder svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .card-body {
    padding: 1.25rem 1.5rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex: 1;
  }

  .card-topic {
    display: inline-block;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--accent);
    text-decoration: none;
    border: 1px solid rgba(186,160,82,0.25);
    padding: 0.18rem 0.6rem;
    border-radius: 999px;
    align-self: flex-start;
  }
  .card-topic:hover {
    background: rgba(186,160,82,0.12);
  }

  .card-body h3 {
    font-family: 'Libre Caslon Text', serif;
    font-size: 1.25rem;
    font-weight: 400;
    line-height: 1.3;
    margin: 0;
    color: var(--text-primary);
  }

  a.card-tag.link {
    text-decoration: none;
  }
  a.card-tag.link:hover {
    background: rgba(140,180,220,0.2);
    color: var(--text-primary);
  }

  .card-summary {
    font-size: 0.95rem;
    color: var(--text-secondary);
    line-height: 1.5;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-top: auto;
    padding-top: 0.5rem;
    font-size: 0.8rem;
  }

  .score {
    font-family: 'Libre Caslon Text', serif;
    font-weight: 700;
    font-size: 0.95rem;
    padding: 0.15rem 0.6rem;
    border-radius: 999px;
    background: rgba(186,160,82,0.18);
    color: rgb(218, 188, 110);
    border: 1px solid rgba(186,160,82,0.3);
  }

  .score[data-score^="9"], .score[data-score="100"] {
    background: rgba(120,180,140,0.18);
    color: rgb(140,200,160);
    border-color: rgba(120,180,140,0.3);
  }

  .rounds {
    color: var(--text-muted);
  }

  .card-tag {
    color: var(--text-secondary);
    background: rgba(140,180,220,0.1);
    padding: 0.1rem 0.55rem;
    border-radius: 999px;
    font-size: 0.75rem;
  }

  .empty {
    text-align: center;
    padding: 4rem 2rem;
    color: var(--text-muted);
    font-style: italic;
  }

  @media (max-width: 640px) {
    .dialog-index { padding: 1rem 1rem 4rem; }
    .hero { padding: 3rem 1.5rem 2.5rem; }
    .hero-stats { gap: 1.5rem; }
    .hero-stats strong { font-size: 1.75rem; }
    .cards { grid-template-columns: 1fr; }
  }
</style>
