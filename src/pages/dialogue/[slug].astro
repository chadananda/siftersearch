---
// Individual dialog page — live from API (published_conversations table).
// SSR: fetches by slug at request time, no prerender, no getStaticPaths.
import Layout from '../../layouts/Layout.astro';
import LiquidBackground from '../../components/LiquidBackground.svelte';
import NavBar from '../../components/common/NavBar.svelte';
import DialogScrollSpy from '../../components/dialogue/DialogScrollSpy.svelte';
import DialogQuoteMarker from '../../components/dialogue/DialogQuoteMarker.svelte';
import { smartQuotes as sq } from '../../lib/smart-quotes.js';
import { heroUrl, cardUrl } from '../../lib/imagekit.js';

const API_BASE = import.meta.env.PUBLIC_API_URL || 'https://api.siftersearch.com';
const { slug } = Astro.params;

// Fetch this dialog and all published dialogs in parallel
const [dialogRes, allRes] = await Promise.all([
  fetch(`${API_BASE}/api/v1/dialogs/${slug}`),
  fetch(`${API_BASE}/api/v1/dialogs`),
]);

if (!dialogRes.ok) return Astro.redirect('/404');
const { dialog } = await dialogRes.json();
const { dialogs: allPublished = [] } = allRes.ok ? await allRes.json() : {};

const data = {
  ...dialog,
  tags: JSON.parse(dialog.tags_json || '[]'),
  keywords: JSON.parse(dialog.keywords_json || '[]'),
  roundTitles: JSON.parse(dialog.round_titles_json || '[]'),
  assessment: dialog.assessment_json ? JSON.parse(dialog.assessment_json) : null,
};

// Related dialogs — share at least one tag
const tagSet = new Set(data.tags);
const related = allPublished
  .filter(p => p.slug !== slug)
  .map(p => ({ ...p, tags: JSON.parse(p.tags_json || '[]') }))
  .map(p => ({ ...p, overlap: p.tags.filter(t => tagSet.has(t)).length }))
  .filter(p => p.overlap > 0)
  .sort((a, b) => b.overlap - a.overlap || new Date(b.published_at).getTime() - new Date(a.published_at).getTime())
  .slice(0, 12);

const allRecent = [...allPublished].sort((a, b) => new Date(b.published_at).getTime() - new Date(a.published_at).getTime());

const linkableTags = data.tags;

// Schema.org structured data
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": data.title,
  "description": data.description,
  "datePublished": data.published_at,
  "dateModified": data.updated_at || data.published_at,
  "author": [
    { "@type": "Person", "name": "Reader" },
    { "@type": "SoftwareApplication", "name": "Jafar (SifterSearch)" }
  ],
  "publisher": {
    "@type": "Organization",
    "name": "SifterSearch",
    "logo": { "@type": "ImageObject", "url": "https://siftersearch.com/logo.svg" }
  },
  "image": data.hero_image ? heroUrl(data.hero_image) : undefined,
  "keywords": data.tags.join(', ')
};

// FAQPage schema — built from round_titles_json + body_html jafar-turn divs
const jafarTurnRegex = /<div class="jafar-turn">([\s\S]*?)<\/div>/g;
const jafarAnswers: string[] = [];
let m;
while ((m = jafarTurnRegex.exec(dialog.body_html || '')) !== null) {
  const text = m[1].replace(/<[^>]+>/g, '').trim();
  if (text) jafarAnswers.push(text);
}
const faqEntries = data.roundTitles
  .map((rt, i) => ({ q: rt.user, a: jafarAnswers[i] }))
  .filter(p => p.q && p.a);
const faqSchema = faqEntries.length >= 3 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqEntries.map(p => ({
    "@type": "Question",
    "name": p.q,
    "acceptedAnswer": { "@type": "Answer", "text": p.a.slice(0, 600) }
  }))
} : null;

const TOPIC_LABELS: Record<string, string> = {
  'theology': 'Theology',
  'ethics': 'Ethics',
  'social-order': 'Social Order',
  'politics': 'Politics',
  'history': 'History',
  'comparative-religion': 'Comparative Religion',
  'mysticism': 'Mysticism',
  'practice': 'Practice',
  'modern-challenges': 'Modern Challenges',
  'word-meaning': 'Word & Meaning',
  'metaphysics': 'Metaphysics',
  'philosophy': 'Philosophy',
};
---

<Layout
  title={`${sq(data.title)} — Dialog`}
  description={sq(data.description)}
  image={data.hero_image ? heroUrl(data.hero_image) : '/og-image.png'}
  type="article"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
    <link rel="alternate" type="application/rss+xml" title="SifterSearch Dialogs" href="/dialogue/rss.xml" />
  </Fragment>

  <LiquidBackground client:only="svelte" />
  <NavBar currentPage="dialog" client:load />

  <article class="dialog-page">
    <div class="dialog-hero">
      {data.hero_image ? (
        <img class="hero-image" src={heroUrl(data.hero_image)} alt={data.title} />
      ) : (
        <div class="hero-watercolor" aria-hidden="true">
          <svg viewBox="0 0 1200 480" preserveAspectRatio="xMidYMid slice">
            <defs>
              <radialGradient id="hw1" cx="25%" cy="40%" r="55%">
                <stop offset="0%" stop-color="rgba(56,114,184,0.65)" />
                <stop offset="100%" stop-color="rgba(20,52,98,0)" />
              </radialGradient>
              <radialGradient id="hw2" cx="75%" cy="60%" r="50%">
                <stop offset="0%" stop-color="rgba(140,180,220,0.55)" />
                <stop offset="100%" stop-color="rgba(20,52,98,0)" />
              </radialGradient>
              <radialGradient id="hw3" cx="50%" cy="85%" r="40%">
                <stop offset="0%" stop-color="rgba(186,160,82,0.25)" />
                <stop offset="100%" stop-color="rgba(20,52,98,0)" />
              </radialGradient>
            </defs>
            <rect width="1200" height="480" fill="rgba(20,52,98,0.5)" />
            <rect width="1200" height="480" fill="url(#hw1)" />
            <rect width="1200" height="480" fill="url(#hw2)" />
            <rect width="1200" height="480" fill="url(#hw3)" />
            <path d="M 60 280 Q 320 180 580 240 T 1140 200" stroke="rgba(20,52,98,0.4)" stroke-width="2.5" fill="none" stroke-linecap="round" />
            <path d="M 80 340 Q 380 280 700 320 T 1150 290" stroke="rgba(140,180,220,0.4)" stroke-width="1.5" fill="none" stroke-linecap="round" />
          </svg>
        </div>
      )}
    </div>

    <div class="dialog-container">
      <header class="dialog-header">
        <a href={`/dialogue/category/${data.topic}/`} class="topic-crumb">{TOPIC_LABELS[data.topic] ?? data.topic}</a>
        <h1>{sq(data.title)}</h1>
        <p class="seed-question">
          {sq(data.question)}
        </p>
        <div class="dialog-meta">
          {data.score > 0 && (
            <span class="meta-score">
              <span class="meta-label">Quality</span>
              <strong>{data.score}%</strong>
            </span>
          )}
          <span class="meta-rounds">
            <span class="meta-label">Rounds</span>
            <strong>{data.rounds_count}</strong>
          </span>
          <span class="meta-date">
            <span class="meta-label">Published</span>
            <strong>{new Date(data.published_at).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</strong>
          </span>
        </div>
        {linkableTags.length > 0 && (
          <div class="dialog-tags">
            {linkableTags.map(t => (
              <a class="dialog-tag" href={`/dialogue/tag/${encodeURIComponent(t)}/`}>{t}</a>
            ))}
          </div>
        )}
      </header>

      <div class="dialog-layout">
        <!-- LEFT: TOC + related below it (stacked in the left column) -->
        <aside class="toc-rail" aria-label="Conversation rounds">
          <p class="rail-label">Conversation</p>
          <ol class="toc-list">
            {data.roundTitles.map((rt, i) => (
              <li class="toc-round">
                <a class="toc-q" href={`#round-${i + 1}`}>{sq(rt.user)}</a>
                {rt.jafar && <a class="toc-a" href={`#round-${i + 1}-answer`}>{sq(rt.jafar)}</a>}
              </li>
            ))}
            <li class="toc-spacer" />
            {data.assessment && <li><a href="#assessment" class="toc-assess">Assessment</a></li>}
          </ol>

          {related.length > 0 && (
            <div class="toc-related">
              <p class="rail-label">Related</p>
              <ul class="related-list">
                {related.map(r => (
                  <li>
                    <a href={`/dialogue/${r.slug}/`} class="related-card">
                      {r.hero_image && <img src={cardUrl(r.hero_image)} alt="" loading="lazy" />}
                      <span class="related-text">
                        <span class="related-title">{sq(r.title)}</span>
                        <span class="related-topic">{TOPIC_LABELS[r.topic] ?? r.topic}</span>
                      </span>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </aside>

        <!-- CENTER: the dialog body itself -->
        <div class="dialog-body prose">
          <Fragment set:html={dialog.body_html} />
        </div>
      </div>

      {data.assessment && (() => {
        const a = data.assessment;
        const s = a.scores || {};
        const dims = [
          ['depth', 'Depth'],
          ['evidence_quality', 'Evidence'],
          ['citation_integrity', 'Citations'],
          ['doctrinal_fidelity', 'Doctrine'],
          ['conversational_realism', 'Tone'],
          ['brevity_discipline', 'Brevity'],
          ['correction_courage', 'Honesty'],
          ['period_word_discipline', 'Period Vocab'],
          ['archive_worthy', 'Archive-Worthy'],
        ];
        return (
          <section class="assessment-box" id="assessment" aria-label="Conversation assessment">
            <div class="assess-header">
              <span class="assess-label">Quality Assessment</span>
              <a href="/dialogue/assessment" class="assess-link">How we assess →</a>
            </div>
            <div class="assess-scores">
              {dims.map(([key, label]) => s[key] != null && (
                <div class="score-cell">
                  <span class="score-val" data-score={String(s[key])}>{s[key]}</span>
                  <span class="score-dim">{label}</span>
                </div>
              ))}
            </div>
            {a.flags?.length > 0 && (
              <div class="assess-flags">
                {a.flags.map((f: string) => (
                  <a href="/dialogue/assessment" class="flag">{f}</a>
                ))}
              </div>
            )}
            {a.narrative && (
              <div class="assess-narrative">
                <h3>Narrative</h3>
                <p>{a.narrative}</p>
              </div>
            )}
            {a.improvement_plan && (
              <div class="assess-plan">
                <h3>Improvement Notes</h3>
                <p>{a.improvement_plan}</p>
              </div>
            )}
          </section>
        );
      })()}

      <footer class="dialog-footer">
        <div class="footer-watermark" aria-hidden="true">
          <svg viewBox="0 0 400 80" preserveAspectRatio="xMidYMid meet">
            <path d="M 30 40 Q 100 20 200 40 T 370 40" stroke="rgba(56,114,184,0.4)" stroke-width="1.5" fill="none" stroke-linecap="round" />
            <circle cx="200" cy="40" r="4" fill="rgba(186,160,82,0.6)" />
          </svg>
        </div>
        <p class="footer-note">
          This conversation was held with <strong>Jafar</strong>, SifterSearch's library-grounded chat.
          Citations are pulled from the actual interfaith corpus.
          <a href="/">Try your own question →</a>
        </p>

        <nav class="footer-grid" aria-label="Site resources">
          <div class="footer-col">
            <h4>Dialog</h4>
            <a href="/dialogue/">All conversations</a>
            <a href="/dialogue/assessment">How these are assessed</a>
            <a href={`/dialogue/category/${data.topic}/`}>{TOPIC_LABELS[data.topic] ?? data.topic}</a>
          </div>
          <div class="footer-col">
            <h4>Library</h4>
            <a href="/library/">Browse the library</a>
            <a href="/">Search & chat</a>
            <a href="/about/">About SifterSearch</a>
          </div>
          {linkableTags.length > 0 && (
            <div class="footer-col">
              <h4>Tags on this dialog</h4>
              {linkableTags.slice(0, 6).map(t => (
                <a href={`/dialogue/tag/${encodeURIComponent(t)}/`}>{t}</a>
              ))}
            </div>
          )}
          {allRecent.length > 0 && (
            <div class="footer-col">
              <h4>Recent dialogs</h4>
              {allRecent.slice(0, 5).filter(r => r.slug !== slug).slice(0, 5).map(r => (
                <a href={`/dialogue/${r.slug}/`}>{sq(r.title)}</a>
              ))}
            </div>
          )}
        </nav>
      </footer>
    </div>
  </article>

  <!-- Auto-mark quote paragraphs: when Jafar quotes a passage as a regular
       paragraph instead of a markdown blockquote, the visual styling is lost.
       Detect "long paragraphs that open with a quote and close with a quote
       + citation" and tag them so .dialog-body p[data-quote-paragraph="true"]
       can style them like blockquotes. -->
  <DialogQuoteMarker client:idle />
  <DialogScrollSpy client:idle />
</Layout>

<style>
  .dialog-page { color: var(--text-primary); }

  .dialog-hero {
    width: 100%;
    height: clamp(280px, 38vh, 480px);
    overflow: hidden;
    position: relative;
  }

  .hero-image, .hero-watercolor svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .dialog-hero::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(15,30,55,0) 0%, rgba(15,30,55,0.3) 60%, var(--surface-0) 100%);
    pointer-events: none;
  }

  .dialog-container {
    max-width: 1280px;
    margin: -100px auto 0;
    padding: 2rem 1.5rem 6rem;
    position: relative;
    z-index: 1;
  }

  /* Two-column layout: TOC+related (240px) | body */
  .dialog-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: start;
    margin-top: 2rem;
  }
  .toc-rail { display: none; }
  .toc-rail {
    position: sticky;
    top: 5rem;
    max-height: calc(100vh - 6rem);
    overflow-y: auto;
    font-family: 'Libre Caslon Text', serif;
    background: rgba(10, 22, 42, 0.55);
    border: 1px solid rgba(140, 180, 220, 0.1);
    border-radius: 12px;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }
  .toc-rail { padding: 1.25rem 0.5rem; }
  .toc-rail .rail-label { padding: 0 0.5rem; }
  .toc-related {
    margin-top: 1.5rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(140, 180, 220, 0.1);
  }
  .toc-related .rail-label { padding: 0 0.5rem; }
  .rail-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--text-muted);
    font-weight: 700;
    margin: 0 0 0.85rem;
  }
  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .toc-list li { margin: 0; padding: 0; }
  /* TOC round rhythm: h4 hugs its h3 (33% gap above), big space below
     to the next round's h3 (66% gap). */
  .toc-round {
    margin-bottom: 1.75rem;
    padding-bottom: 0.6rem;
    border-bottom: 1px dotted rgba(140, 180, 220, 0.08);
  }
  .toc-round:last-of-type { border-bottom: none; }
  .toc-list a {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    padding: 0.2rem 0.4rem;
    font-size: 0.85rem;
    text-decoration: none;
    border-left: 2px solid transparent;
    transition: all 0.15s ease;
    line-height: 1.35;
  }
  .toc-q {
    color: var(--text-primary);
    font-weight: 500;
  }
  .toc-a {
    color: var(--text-muted);
    font-style: italic;
    font-size: 0.78rem !important;
    padding-left: 1rem !important;
    padding-top: 0 !important;
    padding-bottom: 0.6rem !important;
    margin-top: -0.1rem;          /* tight under h3 */
  }
  .toc-a::before {
    content: "→ ";
    opacity: 0.5;
  }
  .toc-list a:hover {
    color: var(--text-primary);
    border-left-color: rgba(186, 160, 82, 0.5);
    background: rgba(186, 160, 82, 0.05);
  }
  /* Scrollspy highlight — currently-visible round in the rail */
  .toc-list a.toc-active {
    color: var(--text-primary);
    border-left-color: rgba(186, 160, 82, 0.85);
    background: rgba(186, 160, 82, 0.08);
  }
  .toc-list a.toc-a.toc-active {
    color: rgb(218, 188, 110);
  }
  .toc-spacer { height: 0.75rem; border-top: 1px solid rgba(140, 180, 220, 0.1); margin: 0.5rem 0; }
  .toc-assess {
    color: rgb(218, 188, 110) !important;
    font-style: italic;
    text-transform: uppercase;
    font-size: 0.78rem !important;
    letter-spacing: 0.08em;
  }

  .related-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .related-card {
    display: flex;
    gap: 0.75rem;
    padding: 0.6rem 0.5rem;
    margin: 0 0 0.4rem;
    text-decoration: none;
    color: inherit;
    border-radius: 8px;
    border: 1px solid transparent;
  }
  .related-card:hover {
    background: rgba(20, 52, 98, 0.4);
    border-color: rgba(140, 180, 220, 0.2);
  }
  .related-card img {
    width: 56px;
    height: 56px;
    object-fit: cover;
    border-radius: 6px;
    flex-shrink: 0;
  }
  .related-text {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 0;
  }
  .related-title {
    font-size: 0.88rem;
    line-height: 1.3;
    color: var(--text-primary);
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }
  .related-topic {
    font-size: 0.7rem;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .rail-empty,
  .rail-explainer {
    font-size: 0.78rem;
    color: var(--text-muted);
    line-height: 1.5;
    margin: 0.5rem 0 0;
    font-style: italic;
  }

  /* Wide (≥860px): toc+related | body (two columns) */
  @media (min-width: 860px) {
    .dialog-layout { grid-template-columns: 240px minmax(0, 1fr); }
    .toc-rail { display: block; }
    .dialog-body { order: 2; }
  }

  /* Below 860px: single column, rail hidden */
  @media (max-width: 859px) {
    .toc-rail { position: static; max-height: none; display: none; }
  }

  .dialog-header {
    text-align: center;
    margin-bottom: 3rem;
    padding: 2.5rem 1.5rem;
    background: rgba(20,52,98,0.45);
    border: 1px solid rgba(140,180,220,0.15);
    border-radius: 20px;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
  }

  .topic-crumb {
    display: inline-block;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--accent);
    text-decoration: none;
    border: 1px solid rgba(186,160,82,0.3);
    padding: 0.3rem 0.9rem;
    border-radius: 999px;
    margin-bottom: 1.25rem;
    transition: all 0.2s ease;
  }

  .topic-crumb:hover { background: rgba(186,160,82,0.12); }

  .dialog-header h1 {
    font-family: 'Libre Caslon Text', serif;
    font-size: clamp(1.75rem, 4.5vw, 3rem);
    font-weight: 400;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin: 0 0 1.5rem;
    color: var(--text-primary);
  }

  .seed-question {
    font-family: 'Libre Caslon Text', serif;
    font-style: italic;
    font-size: 1.2rem;
    line-height: 1.6;
    color: var(--text-secondary);
    border: none;
    margin: 0 0 1.5rem;
    padding: 0 1rem;
    position: relative;
  }

  .seed-question .quote-mark {
    font-size: 4rem;
    line-height: 0;
    color: rgba(186,160,82,0.4);
    margin-right: 0.25rem;
    vertical-align: -0.4em;
  }

  .dialog-meta {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    justify-content: center;
    margin-bottom: 1rem;
  }

  .dialog-meta > span {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    align-items: center;
  }

  .meta-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-muted);
  }

  .dialog-meta strong {
    font-family: 'Libre Caslon Text', serif;
    font-weight: 400;
    font-size: 1.1rem;
    color: var(--text-primary);
  }

  .meta-score strong { color: rgb(218, 188, 110); }

  .dialog-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    justify-content: center;
    margin-top: 1rem;
  }

  .dialog-tag {
    font-size: 0.8rem;
    padding: 0.2rem 0.7rem;
    border-radius: 999px;
    background: rgba(56,114,184,0.15);
    color: var(--text-secondary);
    text-decoration: none;
    border: 1px solid rgba(56,114,184,0.2);
  }

  .dialog-tag:hover { background: rgba(56,114,184,0.3); }

  /* Dialog body — rich typography for the dialogue itself,
     with a darkened translucent panel so the text is legible
     over the liquid background. */
  .dialog-body {
    font-family: 'Libre Caslon Text', serif;
    font-size: 1.0625rem;
    line-height: 1.75;
    color: var(--text-primary);
    background: rgba(10, 22, 42, 0.78);
    border: 1px solid rgba(140, 180, 220, 0.12);
    border-radius: 20px;
    padding: 2.5rem 2.25rem;
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    box-shadow: 0 12px 48px rgba(0, 0, 0, 0.25);
  }

  @media (max-width: 640px) {
    .dialog-body { padding: 1.5rem 1.25rem; border-radius: 14px; }
  }

  /* Round summary headers — present for SEO + TOC anchors. Visually they
     read as a thin decorative label clamped to one line, sitting tight
     against the bubble/avatar that follows. Almost invisible, but discoverable. */
  .dialog-body :global(h3),
  .dialog-body :global(h4) {
    font-family: 'Libre Caslon Text', serif;
    font-weight: 400;
    font-style: italic;
    text-transform: none;
    letter-spacing: 0;
    border: none;
    padding: 0;
    scroll-margin-top: 5rem;
    /* Single line, ellipsis if too long — they're labels, not headlines */
    white-space: nowrap;
