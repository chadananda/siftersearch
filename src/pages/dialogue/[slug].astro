---
// Individual dialog page — long-form rendering of a User ↔ Jafar conversation
// with rich typography, citation styling, and watercolor decorative elements.
import Layout from '../../layouts/Layout.astro';
import LiquidBackground from '../../components/LiquidBackground.svelte';
import NavBar from '../../components/common/NavBar.svelte';
import { getCollection, render } from 'astro:content';
import { smartQuotes as sq } from '../../lib/smart-quotes.js';
import { heroUrl, cardUrl } from '../../lib/imagekit.js';

// Prerender all dialog pages at build time. Required in Astro `output: 'server'`
// mode for getStaticPaths to actually generate routes. Without this the
// slug param has no props at runtime and rendering 500s.
export const prerender = true;

export async function getStaticPaths() {
  const all = await getCollection('dialogs');
  // Each detail page also gets the full published list (for the Related sidebar
  // and cross-linking footer). We compute it once per build and pass via props.
  const published = all.filter(d => d.data.published === true);
  return all.map(d => ({
    params: { slug: d.id.replace(/\.md$/, '') },
    props: {
      dialog: d,
      allPublished: published.map(p => ({
        slug: p.id.replace(/\.md$/, ''),
        title: p.data.title,
        topic: p.data.topic,
        tags: p.data.tags,
        description: p.data.description,
        publishedAt: p.data.publishedAt.toISOString(),
        heroImage: p.data.heroImage,
        score: p.data.qualityScore,
      })),
    },
  }));
}

const { dialog, allPublished } = Astro.props;
const { Content, headings } = await render(dialog);
const data = dialog.data;

// Related dialogs = other published dialogs that share at least one tag.
// Ranked by # shared tags desc, then recency. Cap at 12.
const currentSlug = dialog.id.replace(/\.md$/, '');
const tagSet = new Set(data.tags);
const related = allPublished
  .filter(p => p.slug !== currentSlug)
  .map(p => ({
    ...p,
    overlap: p.tags.filter(t => tagSet.has(t)).length
  }))
  .filter(p => p.overlap > 0)
  .sort((a, b) => b.overlap - a.overlap || (new Date(b.publishedAt)).getTime() - (new Date(a.publishedAt)).getTime())
  .slice(0, 12);

// "All published" used for the right rail when there's room.
const allRecent = allPublished
  .slice()
  .sort((a, b) => (new Date(b.publishedAt)).getTime() - (new Date(a.publishedAt)).getTime());

// Tag counts across the published corpus. We only render a tag chip if at
// least two articles share it (otherwise the tag page would be a dead end).
const tagCounts = new Map<string, number>();
for (const p of allPublished) {
  for (const t of p.tags) tagCounts.set(t, (tagCounts.get(t) || 0) + 1);
}
const linkableTags = data.tags.filter(t => (tagCounts.get(t) || 0) >= 2);

// Schema.org structured data — Article wrapper
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": data.title,
  "description": data.description,
  "datePublished": data.publishedAt.toISOString(),
  "dateModified": (data.updatedAt ?? data.publishedAt).toISOString(),
  "author": [
    { "@type": "Person", "name": "Reader" },
    { "@type": "SoftwareApplication", "name": "Jafar (SifterSearch)" }
  ],
  "publisher": {
    "@type": "Organization",
    "name": "SifterSearch",
    "logo": { "@type": "ImageObject", "url": "https://siftersearch.com/logo.svg" }
  },
  "image": data.heroImage ? `https://siftersearch.com${data.heroImage}` : undefined,
  "keywords": data.tags.join(', ')
};

// FAQPage schema — every round (h3 question summary + Jafar's prose answer)
// becomes a Q&A entry. Strong rich-result signal for Google: the conversation
// renders in search as a collapsible FAQ stack. Pulled from Astro's headings
// (h3 = question summary) and the markdown body (jafar-turn divs hold the
// prose answers).
const roundQuestions = headings.filter(h => h.depth === 3);
const jafarTurnRegex = /<div class="jafar-turn">([\s\S]*?)<\/div>/g;
const jafarAnswers: string[] = [];
{
  // body is in the rendered HTML; we don't have direct access. Pull from the
  // raw markdown via the import (gray-matter loaded by Astro's content).
  // Fallback: empty array — FAQPage will be omitted if we can't pair.
  const raw = (dialog.body || '');
  let m;
  while ((m = jafarTurnRegex.exec(raw)) !== null) {
    // Strip surrounding whitespace and any HTML; keep markdown as-is so
    // the Answer.text field is human-readable.
    const text = m[1].trim();
    if (text) jafarAnswers.push(text);
  }
}
const faqEntries = roundQuestions
  .map((q, i) => ({ q: q.text, a: jafarAnswers[i] }))
  .filter(p => p.q && p.a);
const faqSchema = faqEntries.length >= 3 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqEntries.map(p => ({
    "@type": "Question",
    "name": p.q,
    "acceptedAnswer": {
      "@type": "Answer",
      // Strip the markdown blockquote prefix so the answer reads cleanly
      // in search results. Cap at ~600 chars per answer.
      "text": p.a.replace(/^>\s*/gm, '').slice(0, 600)
    }
  }))
} : null;

// Topic label
const TOPIC_LABELS: Record<string, string> = {
  'theology': 'Theology',
  'ethics': 'Ethics',
  'social-order': 'Social Order',
  'politics': 'Politics',
  'history': 'History',
  'comparative-religion': 'Comparative Religion',
  'mysticism': 'Mysticism',
  'practice': 'Practice',
  'modern-challenges': 'Modern Challenges',
  'word-meaning': 'Word & Meaning',
  'metaphysics': 'Metaphysics',
  'philosophy': 'Philosophy',
};
---

<Layout
  title={`${sq(data.title)} — Dialog`}
  description={sq(data.description)}
  image={data.heroImage ?? '/og-image.png'}
  type="article"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
    <link rel="alternate" type="application/rss+xml" title="SifterSearch Dialogs" href="/dialogue/rss.xml" />
  </Fragment>

  <LiquidBackground client:only="svelte" />
  <NavBar currentPage="dialog" client:load />

  <article class="dialog-page">
    <div class="dialog-hero">
      {data.heroImage ? (
        <img class="hero-image" src={heroUrl(data.heroImage)} alt={data.title} />
      ) : (
        <div class="hero-watercolor" aria-hidden="true">
          <svg viewBox="0 0 1200 480" preserveAspectRatio="xMidYMid slice">
            <defs>
              <radialGradient id="hw1" cx="25%" cy="40%" r="55%">
                <stop offset="0%" stop-color="rgba(56,114,184,0.65)" />
                <stop offset="100%" stop-color="rgba(20,52,98,0)" />
              </radialGradient>
              <radialGradient id="hw2" cx="75%" cy="60%" r="50%">
                <stop offset="0%" stop-color="rgba(140,180,220,0.55)" />
                <stop offset="100%" stop-color="rgba(20,52,98,0)" />
              </radialGradient>
              <radialGradient id="hw3" cx="50%" cy="85%" r="40%">
                <stop offset="0%" stop-color="rgba(186,160,82,0.25)" />
                <stop offset="100%" stop-color="rgba(20,52,98,0)" />
              </radialGradient>
            </defs>
            <rect width="1200" height="480" fill="rgba(20,52,98,0.5)" />
            <rect width="1200" height="480" fill="url(#hw1)" />
            <rect width="1200" height="480" fill="url(#hw2)" />
            <rect width="1200" height="480" fill="url(#hw3)" />
            <path d="M 60 280 Q 320 180 580 240 T 1140 200" stroke="rgba(20,52,98,0.4)" stroke-width="2.5" fill="none" stroke-linecap="round" />
            <path d="M 80 340 Q 380 280 700 320 T 1150 290" stroke="rgba(140,180,220,0.4)" stroke-width="1.5" fill="none" stroke-linecap="round" />
          </svg>
        </div>
      )}
    </div>

    <div class="dialog-container">
      <header class="dialog-header">
        <a href={`/dialogue/category/${data.topic}/`} class="topic-crumb">{TOPIC_LABELS[data.topic] ?? data.topic}</a>
        <h1>{sq(data.title)}</h1>
        <p class="seed-question">
          {sq(data.question)}
        </p>
        <div class="dialog-meta">
          {typeof data.qualityScore === 'number' && (
            <span class="meta-score">
              <span class="meta-label">Quality</span>
              <strong>{data.qualityScore}%</strong>
            </span>
          )}
          <span class="meta-rounds">
            <span class="meta-label">Rounds</span>
            <strong>{data.rounds}</strong>
          </span>
          <span class="meta-date">
            <span class="meta-label">Published</span>
            <strong>{data.publishedAt.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</strong>
          </span>
        </div>
        {linkableTags.length > 0 && (
          <div class="dialog-tags">
            {linkableTags.map(t => (
              <a class="dialog-tag" href={`/dialogue/tag/${encodeURIComponent(t)}/`}>{t}</a>
            ))}
          </div>
        )}
      </header>

      <div class="dialog-layout">
        <!-- LEFT: Table of contents (round-by-round) -->
        <aside class="toc-rail" aria-label="Conversation rounds">
          <p class="rail-label">Conversation</p>
          <ol class="toc-list">
            {(() => {
              // Pair each h3 (user question) with its following h4 (Jafar's answer).
              // Both come from Astro's `headings`. h3 anchors to round-N (the user-turn div).
              const items = [];
              let roundN = 0;
              for (let i = 0; i < headings.length; i++) {
                const h = headings[i];
                if (h.depth === 3) {
                  roundN++;
                  const next = headings[i + 1];
                  const answer = next && next.depth === 4 ? next : null;
                  items.push({ q: h, a: answer, n: roundN });
                }
              }
              return items.map(item => (
                <li class="toc-round">
                  <a class="toc-q" href={`#round-${item.n}`}>{sq(item.q.text)}</a>
                  {item.a && (
                    <a class="toc-a" href={`#${item.a.slug}`}>{sq(item.a.text)}</a>
                  )}
                </li>
              ));
            })()}
            <li class="toc-spacer" />
            <li><a href="#assessment" class="toc-assess">Assessment</a></li>
          </ol>
        </aside>

        <!-- CENTER: the dialog body itself -->
        <div class="dialog-body prose">
          <Content />
        </div>

        <!-- RIGHT: Related conversations (shared tags) -->
        <aside class="related-rail" aria-label="Related conversations">
          <p class="rail-label">Related conversations</p>
          {related.length === 0 ? (
            <p class="rail-empty">No related dialogs yet.</p>
          ) : (
            <ul class="related-list">
              {related.map(r => (
                <li>
                  <a href={`/dialogue/${r.slug}/`} class="related-card">
                    {r.heroImage && <img src={cardUrl(r.heroImage)} alt="" loading="lazy" />}
                    <span class="related-text">
                      <span class="related-title">{sq(r.title)}</span>
                      <span class="related-topic">{TOPIC_LABELS[r.topic] ?? r.topic}</span>
                    </span>
                  </a>
                </li>
              ))}
            </ul>
          )}

          {related.length > 0 && (
            <p class="rail-explainer">
              Sharing tags with this dialog: {Array.from(tagSet).slice(0, 5).join(', ')}.
            </p>
          )}
        </aside>
      </div>

      {data.assessment && (
        <aside id="assessment" class="assessment-box" aria-label="Editorial assessment">
          <header class="assess-header">
            <span class="assess-label">Assessment</span>
            <a class="assess-link" href="/dialogue/assessment">how this is assessed →</a>
          </header>

          <div class="assess-scores">
            {Object.entries(data.assessment.scores).map(([dim, val]) => (
              <div class="score-cell">
                <span class="score-val" data-score={val}>{val}</span>
                <span class="score-dim">{dim.replace(/_/g, ' ')}</span>
              </div>
            ))}
          </div>

          <div class="assess-narrative">
            <h3>What worked, what didn't</h3>
            <p>{sq(data.assessment.narrative)}</p>
          </div>

          {data.assessment.flags && data.assessment.flags.length > 0 && (
            <div class="assess-flags">
              {data.assessment.flags.map(f => (
                <a class="flag" href={`/dialogue/assessment#failure-modes`} title="see methodology">{f}</a>
              ))}
            </div>
          )}

          <div class="assess-plan">
            <h3>Forward — what should change</h3>
            <p>{sq(data.assessment.improvement_plan)}</p>
          </div>
        </aside>
      )}

      <footer class="dialog-footer">
        <div class="footer-watermark" aria-hidden="true">
          <svg viewBox="0 0 400 80" preserveAspectRatio="xMidYMid meet">
            <path d="M 30 40 Q 100 20 200 40 T 370 40" stroke="rgba(56,114,184,0.4)" stroke-width="1.5" fill="none" stroke-linecap="round" />
            <circle cx="200" cy="40" r="4" fill="rgba(186,160,82,0.6)" />
          </svg>
        </div>
        <p class="footer-note">
          This conversation was held with <strong>Jafar</strong>, SifterSearch's library-grounded chat.
          Citations are pulled from the actual interfaith corpus.
          <a href="/">Try your own question →</a>
        </p>

        <nav class="footer-grid" aria-label="Site resources">
          <div class="footer-col">
            <h4>Dialog</h4>
            <a href="/dialogue/">All conversations</a>
            <a href="/dialogue/assessment">How these are assessed</a>
            <a href={`/dialogue/category/${data.topic}/`}>{TOPIC_LABELS[data.topic] ?? data.topic}</a>
          </div>
          <div class="footer-col">
            <h4>Library</h4>
            <a href="/library/">Browse the library</a>
            <a href="/">Search & chat</a>
            <a href="/about/">About SifterSearch</a>
          </div>
          {linkableTags.length > 0 && (
            <div class="footer-col">
              <h4>Tags on this dialog</h4>
              {linkableTags.slice(0, 6).map(t => (
                <a href={`/dialogue/tag/${encodeURIComponent(t)}/`}>{t}</a>
              ))}
            </div>
          )}
          {allRecent.length > 0 && (
            <div class="footer-col">
              <h4>Recent dialogs</h4>
              {allRecent.slice(0, 5).filter(r => r.slug !== currentSlug).slice(0, 5).map(r => (
                <a href={`/dialogue/${r.slug}/`}>{sq(r.title)}</a>
              ))}
            </div>
          )}
        </nav>
      </footer>
    </div>
  </article>

  <!-- TOC scrollspy: highlight the currently-visible round in the rail -->
  <script>
    (() => {
      const rounds = Array.from(document.querySelectorAll('.dialog-body .user-turn[id]'));
      if (!rounds.length) return;
      const tocLinks = new Map();  // round-N → toc anchor element
      for (const r of rounds) {
        const a = document.querySelector(`.toc-rail a[href="#${r.id}"]`);
        if (a) tocLinks.set(r.id, a);
      }
      let active = null;
      const setActive = (id) => {
        if (active === id) return;
        if (active) tocLinks.get(active)?.classList.remove('toc-active');
        active = id;
        const link = tocLinks.get(id);
        if (link) {
          link.classList.add('toc-active');
          // Also activate the paired h4 underneath, if present
          const h4 = link.parentElement?.querySelector('.toc-a');
          h4?.classList.add('toc-active');
          // Clear the previous round's h4 highlight
          for (const [otherId, otherA] of tocLinks) {
            if (otherId !== id) {
              const otherH4 = otherA.parentElement?.querySelector('.toc-a');
              otherH4?.classList.remove('toc-active');
            }
          }
        }
      };
      const io = new IntersectionObserver(
        (entries) => {
          // Pick the entry closest to the top of the viewport that is intersecting.
          const visible = entries.filter(e => e.isIntersecting);
          if (visible.length) {
            visible.sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
            setActive(visible[0].target.id);
          }
        },
        { rootMargin: '-20% 0px -60% 0px', threshold: 0 }
      );
      rounds.forEach(r => io.observe(r));
    })();
  </script>
</Layout>

<style>
  .dialog-page { color: var(--text-primary); }

  .dialog-hero {
    width: 100%;
    height: clamp(280px, 38vh, 480px);
    overflow: hidden;
    position: relative;
  }

  .hero-image, .hero-watercolor svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .dialog-hero::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(15,30,55,0) 0%, rgba(15,30,55,0.3) 60%, var(--surface-0) 100%);
    pointer-events: none;
  }

  .dialog-container {
    max-width: 1280px;
    margin: -100px auto 0;
    padding: 2rem 1.5rem 6rem;
    position: relative;
    z-index: 1;
  }

  /* Three-column layout: TOC (260px) | body (flex) | related (320px) */
  .dialog-layout {
    display: grid;
    grid-template-columns: 260px minmax(0, 1fr) 320px;
    gap: 2.5rem;
    align-items: start;
    margin-top: 2rem;
  }
  .toc-rail, .related-rail {
    position: sticky;
    top: 5rem;
    max-height: calc(100vh - 6rem);
    overflow-y: auto;
    font-family: 'Libre Caslon Text', serif;
    background: rgba(10, 22, 42, 0.55);
    border: 1px solid rgba(140, 180, 220, 0.1);
    border-radius: 12px;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }
  .toc-rail { padding: 1.25rem 0.5rem; }
  .related-rail { padding: 1.25rem 1rem; }
  .toc-rail .rail-label { padding: 0 0.5rem; }
  .rail-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--text-muted);
    font-weight: 700;
    margin: 0 0 0.85rem;
  }
  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .toc-list li { margin: 0; padding: 0; }
  /* TOC round rhythm: h4 hugs its h3 (33% gap above), big space below
     to the next round's h3 (66% gap). */
  .toc-round {
    margin-bottom: 1.2rem;        /* large gap to next round */
    padding-bottom: 0.4rem;
    border-bottom: 1px dotted rgba(140, 180, 220, 0.08);
  }
  .toc-round:last-of-type { border-bottom: none; }
  .toc-list a {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    padding: 0.2rem 0.4rem;
    font-size: 0.85rem;
    text-decoration: none;
    border-left: 2px solid transparent;
    transition: all 0.15s ease;
    line-height: 1.35;
  }
  .toc-q {
    color: var(--text-primary);
    font-weight: 500;
  }
  .toc-a {
    color: var(--text-muted);
    font-style: italic;
    font-size: 0.78rem !important;
    padding-left: 1rem !important;
    padding-top: 0 !important;
    margin-top: -0.1rem;          /* tight under h3 */
  }
  .toc-a::before {
    content: "→ ";
    opacity: 0.5;
  }
  .toc-list a:hover {
    color: var(--text-primary);
    border-left-color: rgba(186, 160, 82, 0.5);
    background: rgba(186, 160, 82, 0.05);
  }
  /* Scrollspy highlight — currently-visible round in the rail */
  .toc-list a.toc-active {
    color: var(--text-primary);
    border-left-color: rgba(186, 160, 82, 0.85);
    background: rgba(186, 160, 82, 0.08);
  }
  .toc-list a.toc-a.toc-active {
    color: rgb(218, 188, 110);
  }
  .toc-spacer { height: 0.75rem; border-top: 1px solid rgba(140, 180, 220, 0.1); margin: 0.5rem 0; }
  .toc-assess {
    color: rgb(218, 188, 110) !important;
    font-style: italic;
    text-transform: uppercase;
    font-size: 0.78rem !important;
    letter-spacing: 0.08em;
  }

  .related-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .related-card {
    display: flex;
    gap: 0.75rem;
    padding: 0.6rem 0.5rem;
    margin: 0 0 0.4rem;
    text-decoration: none;
    color: inherit;
    border-radius: 8px;
    border: 1px solid transparent;
  }
  .related-card:hover {
    background: rgba(20, 52, 98, 0.4);
    border-color: rgba(140, 180, 220, 0.2);
  }
  .related-card img {
    width: 56px;
    height: 56px;
    object-fit: cover;
    border-radius: 6px;
    flex-shrink: 0;
  }
  .related-text {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 0;
  }
  .related-title {
    font-size: 0.88rem;
    line-height: 1.3;
    color: var(--text-primary);
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }
  .related-topic {
    font-size: 0.7rem;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .rail-empty,
  .rail-explainer {
    font-size: 0.78rem;
    color: var(--text-muted);
    line-height: 1.5;
    margin: 0.5rem 0 0;
    font-style: italic;
  }

  /* Below 1100px: hide right rail. Below 900px: hide both rails (mobile). */
  @media (max-width: 1100px) {
    .dialog-layout {
      grid-template-columns: 220px minmax(0, 1fr);
    }
    .related-rail { display: none; }
  }
  @media (max-width: 900px) {
    .dialog-layout {
      grid-template-columns: 1fr;
    }
    .toc-rail, .related-rail {
      position: static;
      max-height: none;
    }
    .toc-rail {
      order: 2;
      margin-top: 2rem;
    }
  }

  .dialog-header {
    text-align: center;
    margin-bottom: 3rem;
    padding: 2.5rem 1.5rem;
    background: rgba(20,52,98,0.45);
    border: 1px solid rgba(140,180,220,0.15);
    border-radius: 20px;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
  }

  .topic-crumb {
    display: inline-block;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--accent);
    text-decoration: none;
    border: 1px solid rgba(186,160,82,0.3);
    padding: 0.3rem 0.9rem;
    border-radius: 999px;
    margin-bottom: 1.25rem;
    transition: all 0.2s ease;
  }

  .topic-crumb:hover { background: rgba(186,160,82,0.12); }

  .dialog-header h1 {
    font-family: 'Libre Caslon Text', serif;
    font-size: clamp(1.75rem, 4.5vw, 3rem);
    font-weight: 400;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin: 0 0 1.5rem;
    color: var(--text-primary);
  }

  .seed-question {
    font-family: 'Libre Caslon Text', serif;
    font-style: italic;
