---
// Per-tag landing page. Generated only for tags shared by ≥2 published
// dialogs (the bar for surfacing a tag to users at all). SEO-rich:
// title/description tuned to the tag, lists every dialog with that tag.
import Layout from '../../../layouts/Layout.astro';
import LiquidBackground from '../../../components/LiquidBackground.svelte';
import NavBar from '../../../components/common/NavBar.svelte';
import { getCollection } from 'astro:content';
import { smartQuotes as sq } from '../../../lib/smart-quotes.js';
import { cardUrl } from '../../../lib/imagekit.js';

export const prerender = true;

export async function getStaticPaths() {
  const all = await getCollection('dialogs');
  const published = all.filter(d => d.data.published === true);
  const tagToDialogs = new Map<string, typeof published>();
  for (const d of published) {
    for (const t of d.data.tags) {
      const arr = tagToDialogs.get(t) ?? [];
      arr.push(d);
      tagToDialogs.set(t, arr);
    }
  }
  return Array.from(tagToDialogs.entries())
    .filter(([, dialogs]) => dialogs.length >= 2)
    .map(([tag, dialogs]) => ({
      params: { tag },
      props: {
        tag,
        dialogs: dialogs.sort((a, b) =>
          (b.data.updatedAt ?? b.data.publishedAt).getTime() -
          (a.data.updatedAt ?? a.data.publishedAt).getTime()
        )
      }
    }));
}

const { tag, dialogs } = Astro.props;

const TOPIC_LABELS: Record<string, string> = {
  'theology': 'Theology', 'ethics': 'Ethics', 'social-order': 'Social Order',
  'politics': 'Politics', 'history': 'History', 'comparative-religion': 'Comparative Religion',
  'mysticism': 'Mysticism', 'practice': 'Practice', 'modern-challenges': 'Modern Challenges',
  'word-meaning': 'Word & Meaning', 'metaphysics': 'Metaphysics', 'philosophy': 'Philosophy',
};

const tagDisplay = tag.replace(/-/g, ' ');
const description = `${dialogs.length} long-form dialogues exploring "${tagDisplay}" — primary-source-grounded conversations on faith, doctrine, and meaning.`;
---

<Layout title={`${tagDisplay} — Dialog`} description={description}>
  <LiquidBackground client:only="svelte" />
  <NavBar currentPage="dialog" client:load />

  <main class="tag-page">
    <header>
      <a href="/dialogue" class="back">← all dialogs</a>
      <p class="kicker">tag</p>
      <h1>{tagDisplay}</h1>
      <p class="lead">{dialogs.length} dialogs explore this thread.</p>
    </header>

    <div class="cards">
      {dialogs.map(d => (
        <a class="card" href={`/dialogue/${d.id.replace(/\.md$/, '')}/`}>
          {d.data.heroImage && (
            <img class="card-image" src={cardUrl(d.data.heroImage)} alt={d.data.title} loading="lazy" />
          )}
          <div class="card-body">
            <span class="card-topic">{TOPIC_LABELS[d.data.topic] ?? d.data.topic}</span>
            <h3>{sq(d.data.title)}</h3>
            <p>{sq(d.data.description)}</p>
            {typeof d.data.qualityScore === 'number' && (
              <span class="score">{d.data.qualityScore}%</span>
            )}
          </div>
        </a>
      ))}
    </div>
  </main>
</Layout>

<style>
  .tag-page { max-width: 1100px; margin: 0 auto; padding: 2rem 1.5rem 6rem; color: var(--text-primary); font-family: 'Libre Caslon Text', serif; }
  .back { font-size: 0.85rem; color: var(--text-muted); text-decoration: none; }
  .back:hover { color: var(--accent); }
  .kicker { margin: 1rem 0 0.25rem; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.18em; color: var(--text-muted); }
  h1 { font-size: clamp(2.5rem, 6vw, 4rem); margin: 0 0 0.5rem; line-height: 1; font-weight: 400; }
  .lead { color: var(--text-secondary); font-size: 1.1rem; margin: 0 0 3rem; }
  .cards { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1.5rem; }
  .card { display: flex; flex-direction: column; background: rgba(20,52,98,0.18); border: 1px solid rgba(140,180,220,0.12); border-radius: 16px; overflow: hidden; text-decoration: none; color: inherit; transition: transform 0.2s, border-color 0.2s; }
  .card:hover { transform: translateY(-3px); border-color: rgba(140,180,220,0.35); }
  .card-image { width: 100%; aspect-ratio: 5/3; object-fit: cover; }
  .card-body { padding: 1.25rem 1.5rem 1.5rem; display: flex; flex-direction: column; gap: 0.6rem; }
  .card-topic { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.14em; color: var(--accent); align-self: flex-start; padding: 0.15rem 0.55rem; border: 1px solid rgba(186,160,82,0.25); border-radius: 999px; }
  h3 { font-size: 1.2rem; margin: 0; font-weight: 400; line-height: 1.3; }
  p { margin: 0; color: var(--text-secondary); font-size: 0.95rem; line-height: 1.5; }
  .score { align-self: flex-start; padding: 0.15rem 0.6rem; background: rgba(186,160,82,0.18); color: rgb(218,188,110); border-radius: 999px; font-size: 0.85rem; font-weight: 700; }
</style>
