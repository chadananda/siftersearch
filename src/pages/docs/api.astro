  "author": "Baha'u'llah",
  "religion": "Baha'i",
  "collection": "Core Publications",
  "language": "en",
  "year": 1858,
  "description": "A collection of ethical and mystical utterances...",
  "paragraphCount": 153,
  "url": "https://siftersearch.com/read/hidden_words",
  "createdAt": "2024-01-15T00:00:00Z",
  "updatedAt": "2024-12-14T00:00:00Z"
&#125;</code></pre>

