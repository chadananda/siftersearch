        <th>Parameter</th>
        <th>Type</th>
        <th>Description</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td><code>religion</code></td>
        <td>string</td>
        <td>Filter authors by religion</td>
      </tr>
      <tr>
        <td><code>q</code></td>
        <td>string</td>
        <td>Search authors by name</td>
      </tr>
      <tr>
        <td><code>limit</code></td>
        <td>integer</td>
        <td>Max results (1-500, default: 100)</td>
      </tr>
      <tr>
        <td><code>offset</code></td>
        <td>integer</td>
