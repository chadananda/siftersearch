        &#123; "name": "Letters", "documentCount": 124 &#125;
      ]
    &#125;,
    &#123;
      "name": "Buddhism",
      "documentCount": 196,
      "collections": [
        &#123; "name": "Pali Canon", "documentCount": 89 &#125;,
        &#123; "name": "Mahayana Sutras", "documentCount": 107 &#125;
      ]
    &#125;
  ]
&#125;</code></pre>

