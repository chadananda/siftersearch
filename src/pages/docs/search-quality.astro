---
import DocsLayout from '../../layouts/DocsLayout.astro';
import reportData from '../../../tests/quality/results-latest.json';
import historyData from '../../../tests/quality/history.json';
import analysisData from '../../../tests/quality/analysis.json';
import changesData from '../../../tests/quality/changes.json';

const report = reportData || null;
const history = Array.isArray(historyData) ? historyData : [];
const analysis = analysisData?.generated_at ? analysisData : null;
const changes = Array.isArray(changesData) ? changesData : [];

const categoryLabels = {
  'phrase-match': 'Phrase Match',
  'concept-match': 'Concept Match',
  'authority-ranking': 'Authority Ranking',
  'cross-tradition': 'Cross-Tradition',
  'entity-aware': 'Entity-Aware',
};

function passClass(rate) {
  if (rate >= 80) return 'pass-high';
  if (rate >= 60) return 'pass-mid';
  return 'pass-low';
}

function gaugeColor(score) {
  if (score == null) return 'var(--border)';
  if (score >= 80) return 'var(--success)';
  if (score >= 60) return 'var(--warning)';
  return 'var(--error)';
}

function failReasons(r) {
  if (r.error) return ['timeout'];
  const f = [];
  if (r.rank === null) f.push('not found');
  else if (!r.text_hit) f.push('text mismatch');
  if (!r.anti_hit) f.push('anti-test');
  if (!r.authority_hit) f.push('authority');
  return f;
}

function fmtDate(s) {
  return new Date(s).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric', hour: '2-digit', minute: '2-digit' });
}

function rankBuckets(results) {
  const buckets = { 1: 0, '2-3': 0, '4-10': 0, NF: 0 };
  for (const r of results) {
    if (r.rank === 1) buckets[1]++;
    else if (r.rank >= 2 && r.rank <= 3) buckets['2-3']++;
    else if (r.rank >= 4) buckets['4-10']++;
    else buckets.NF++;
  }
  return buckets;
}

function failBreakdown(reportObj) {
  // Prefer pre-computed breakdown from report; fall back to computing from results
  if (reportObj.failure_breakdown) {
    const fb = reportObj.failure_breakdown;
    return {
      notFound: fb.not_found || 0,
      textMiss: fb.text_mismatch || 0,
      antiTest: fb.anti_test || 0,
      authority: fb.authority_low || 0,
      timeout: fb.timed_out || 0,
      httpError: fb.http_error || 0,
      networkError: fb.network_error || 0,
    };
  }
  const results = reportObj.results || [];
  let notFound = 0, textMiss = 0, antiTest = 0, authority = 0, timeout = 0, httpError = 0, networkError = 0;
  for (const r of results.filter(r => !r.ok)) {
    if (r.errorType === 'timeout') { timeout++; continue; }
    if (r.errorType === 'http_error') { httpError++; continue; }
    if (r.errorType === 'network') { networkError++; continue; }
    if (r.error) { networkError++; continue; }
    if (r.rank === null) notFound++;
    else if (!r.text_hit) textMiss++;
    if (!r.anti_hit) antiTest++;
    if (!r.authority_hit) authority++;
  }
  return { notFound, textMiss, antiTest, authority, timeout, httpError, networkError };
}

// Performance score: p50 latency → 0-100
// Target: <500ms = green, 500-2000ms = yellow, >2000ms = red
function perfScore(p50ms) {
  if (p50ms == null) return null;
  if (p50ms <= 300) return 100;
  if (p50ms <= 500) return Math.round(100 - ((p50ms - 300) / 200) * 15);
  if (p50ms <= 1000) return Math.round(85 - ((p50ms - 500) / 500) * 25);
  if (p50ms <= 2000) return Math.round(60 - ((p50ms - 1000) / 1000) * 30);
  if (p50ms <= 5000) return Math.round(30 - ((p50ms - 2000) / 3000) * 30);
  return 0;
}

// Gauge arc: r=40, circumference=251.3, fill based on 0-100 score
function gaugeArc(score) {
  if (score == null) return '0 251.3';
  return `${Math.round(score / 100 * 251.3)} 251.3`;
}

// Build sparkline SVG path from history array
function sparkPath(hist, key, w, h) {
  if (!hist || hist.length < 2) return '';
  const vals = hist.map(h => h[key] ?? 0);
  const min = Math.min(...vals);
  const max = Math.max(...vals);
  const range = max - min || 1;
  const pts = vals.map((v, i) => {
    const x = Math.round((i / (vals.length - 1)) * w);
    const y = Math.round(h - ((v - min) / range) * h);
    return `${x},${y}`;
  });
  return 'M' + pts.join('L');
}

const gauges = report ? [
  { label: 'Pass Rate', score: report.pass_rate, sub: `${report.passed}/${report.total}` },
  { label: 'MRR', score: Math.round(report.mrr * 100), sub: report.mrr.toFixed(3) },
  { label: 'Rank 1', score: report.results ? Math.round(report.results.filter(r => r.rank === 1).length / report.total * 100) : null, sub: `${report.results?.filter(r => r.rank === 1).length ?? '?'} exact` },
  { label: 'Phrase Match', score: report.categories?.['phrase-match']?.pass_rate ?? null, sub: report.categories?.['phrase-match'] ? `${report.categories['phrase-match'].passed}/${report.categories['phrase-match'].total}` : 'n/a' },
  { label: 'Performance', score: perfScore(report.latency_p50_ms), sub: `${report.latency_p50_ms < 1000 ? report.latency_p50_ms + 'ms' : (report.latency_p50_ms/1000).toFixed(1)+'s'} p50` },
] : null;

const ranks = report ? rankBuckets(report.results) : null;
const fails = report ? failBreakdown(report) : null;
---

<DocsLayout
  title="Search Quality Battery"
  description="Live search quality scores across 504 test fixtures — phrase-match, concept-match, cross-tradition, authority-ranking, and entity-aware tests."
  activeSection="search-quality"
>
  <h1>Search Quality</h1>
  <p class="subtitle">
    504 test fixtures across five categories. Scores update when the battery is run and the JSON committed.
    Fixture set adapted from <a href="/docs/ocean-search-testing">David Hunt's ocean-search-testing framework</a>.
  </p>

  <div class="metrics-guide">
    <div class="metrics-guide-title">How to read these scores</div>
    <dl class="metrics-dl">
      <dt>Pass Rate</dt>
      <dd>% of tests where the expected document appeared in the top 10. For tests with an expected doc ID, that's the primary gate. For text-only tests, the result text must contain the expected phrases.</dd>
      <dt>MRR</dt>
      <dd>Mean Reciprocal Rank — average of 1÷rank across all tests. 1.0 = everything found at position 1; 0.5 = average position 2. Higher is better.</dd>
      <dt>Text precision</dt>
      <dd>% of results where the specific paragraph contained the expected phrases. Tracked separately — it's a paragraph-quality signal, not a pass/fail gate. Low text precision means we're finding the right book but returning the wrong paragraph.</dd>
      <dt>Not found</dt>
      <dd>The expected document didn't appear in the top 10 at all. These are the hardest failures requiring index or ranking improvements.</dd>
    </dl>
  </div>

  <!-- ═══ SUITE GAUGES ═══ -->
  <section class="gauge-section">
    <div class="gauge-header">
      <span class="suite-label">Search Quality</span>
      <span class="suite-count">{report ? report.total + ' tests' : '504 tests'}</span>
      {report && <span class="suite-date">{fmtDate(report.run_at)}</span>}
    </div>
    {gauges ? (
      <div class="gauge-row">
        {gauges.map(g => (
          <div class="gauge-cell">
            <svg class="gauge-svg" viewBox="0 0 100 100" aria-label={`${g.label}: ${g.score ?? 'no data'}`}>
              <circle cx="50" cy="50" r="40" fill="none" stroke="var(--surface-3, #e5e7eb)" stroke-width="9"/>
              {g.score != null && (
                <circle
                  cx="50" cy="50" r="40"
                  fill="none"
                  stroke={gaugeColor(g.score)}
                  stroke-width="9"
                  stroke-dasharray={gaugeArc(g.score)}
                  stroke-linecap="round"
                  transform="rotate(-90 50 50)"
                />
              )}
              <text x="50" y="46" text-anchor="middle" class="gauge-num" style={`fill:${g.score != null ? gaugeColor(g.score) : 'var(--text-muted)'}`}>
                {g.score != null ? g.score : '—'}
              </text>
              <text x="50" y="62" text-anchor="middle" class="gauge-sub">{g.sub}</text>
            </svg>
            <div class="gauge-label">{g.label}</div>
          </div>
        ))}
      </div>
    ) : (
      <p class="no-data">Run <code>node tests/quality/score-search.mjs --write-report</code> and commit the results.</p>
    )}
  </section>

  <!-- ═══ HISTORY ═══ -->
  {history.length > 1 && (
    <section>
      <h2>Score History</h2>
      <div class="history-grid">
        <div class="history-chart">
          <div class="history-chart-header">
            <span class="history-range">{history.length} runs · {history[0].run_at.slice(0,10)} → {history[history.length-1].run_at.slice(0,10)}</span>
          </div>
          <svg class="spark" viewBox={`0 0 200 50`} preserveAspectRatio="none">
            <path d={sparkPath(history, 'pass_rate', 200, 50)} class="spark-line"/>
          </svg>
          <div class="history-table-wrap">
            <table class="history-table">
              <thead><tr><th>Date</th><th>Pass%</th><th>MRR</th><th>p50</th></tr></thead>
              <tbody>
                {[...history].reverse().slice(0, 10).map(h => (
                  <tr>
                    <td>{new Date(h.run_at).toLocaleDateString('en-US', {month:'short',day:'numeric',year:'numeric'})}</td>
                    <td class={passClass(h.pass_rate)}>{h.pass_rate}%</td>
                    <td>{h.mrr.toFixed(3)}</td>
                    <td>{h.latency_p50_ms < 1000 ? h.latency_p50_ms+'ms' : (h.latency_p50_ms/1000).toFixed(1)+'s'}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- ═══ CATEGORY BREAKDOWN ═══ -->
  {report && (
    <section>
      <h2>By Category</h2>
      <div class="cat-bars">
        {Object.entries(report.categories).map(([cat, stats]) => (
          <div class="cat-row">
            <span class="cat-label">{categoryLabels[cat] || cat}</span>
            <div class="cat-bar-wrap">
              <div class={`cat-bar-fill ${passClass(stats.pass_rate)}`} style={`width:${stats.pass_rate}%`}></div>
            </div>
            <span class={`cat-pct ${passClass(stats.pass_rate)}`}>{stats.pass_rate}%</span>
            <span class="cat-frac">{stats.passed}/{stats.total}</span>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- ═══ RANK DISTRIBUTION ═══ -->
  {ranks && (
    <section>
      <h2>Rank Distribution</h2>
      <div class="rank-dist-grid">
        <div class="rank-dist">
          {[['Rank 1', ranks[1], 'success'], ['Rank 2–3', ranks['2-3'], 'warning'], ['Rank 4–10', ranks['4-10'], 'info'], ['Not found', ranks.NF, 'error']].map(([lbl, n, cls]) => (
            <div class="rank-row">
              <span class="rank-lbl">{lbl}</span>
              <div class="rank-bar-wrap">
                <div class={`rank-bar-fill rank-${cls}`} style={`width:${Math.round(n/(report?.total||1)*100)}%`}></div>
              </div>
              <span class="rank-n">{n}</span>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ═══ FAILURE BREAKDOWN ═══ -->
  {fails && report && report.fail > 0 && (() => {
    return (
      <section>
        <h2>Failure Breakdown</h2>
        <div class="fail-grid">
          <div class="fail-card">
            <div class="fail-title">Failures ({report.fail})</div>
            {[
              ['Not found in top 10', fails.notFound],
              ['Text mismatch', fails.textMiss],
              ['Anti-test failed', fails.antiTest],
              ['Authority too low', fails.authority],
              ['Timed out', fails.timeout],
              ['HTTP error (5xx)', fails.httpError],
              ['Network/other error', fails.networkError],
            ].filter(([,n]) => n > 0).map(([lbl, n]) => (
              <div class="fail-row">
                <span class="fail-lbl">{lbl}</span>
                <div class="fail-bar-wrap">
                  <div class="fail-bar-fill" style={`width:${Math.round(n/report.fail*100)}%`}></div>
                </div>
                <span class="fail-n">{n}</span>
              </div>
            ))}
          </div>
        </div>
      </section>
    );
  })()}

  <!-- ═══ FAILING TESTS TABLE ═══ -->
  {report && report.results.filter(r => !r.ok).length > 0 && (
    <section>
      <h2>Failing Tests</h2>
      <table class="fail-table">
        <thead>
          <tr><th>Query</th><th>Cat</th><th>Rank</th><th>Top hit</th><th>Reason</th></tr>
        </thead>
        <tbody>
          {report.results.filter(r => !r.ok).map(r => (
            <tr>
              <td class="q-cell">{r.query}</td>
              <td class="cat-cell">{(categoryLabels[r.category] || r.category).replace(' ', '\u00a0')}</td>
              <td class={r.rank ? 'rank-cell' : 'rank-cell nf'}>{r.rank ?? 'NF'}</td>
              <td class="hit-cell">{r.top_hit_title ? `${r.top_hit_author} — ${r.top_hit_title.slice(0,40)}` : '—'}</td>
              <td class="reason-cell">{failReasons(r).join(', ')}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>
  )}

  <!-- ═══ CHANGE LOG ═══ -->
  {changes.length > 0 && (
    <section>
      <h2>Change Log</h2>
      <p class="section-note">Interventions applied to improve search quality. Updated manually when a change ships.</p>
      <table class="change-table">
        <thead><tr><th>Date</th><th>Change</th><th>Result</th></tr></thead>
        <tbody>
          {[...changes].reverse().map(c => (
            <tr>
              <td class="change-date">{c.date}</td>
              <td class="change-desc">{c.description}</td>
              <td class="change-result">{c.result}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>
  )}

  <!-- ═══ ANALYSIS ═══ -->
  {analysis && (
    <section class="analysis-section">
      <h2>Analysis &amp; Improvement Strategy</h2>
      <p class="section-note">
        Generated by {analysis.model} on {new Date(analysis.generated_at).toLocaleDateString('en-US', {month:'long',day:'numeric',year:'numeric'})}.
        Re-run with <code>--analyze</code> flag to update.
      </p>

      {[analysis].map(a => (
        <div class="analysis-block">
          <div class="analysis-suite-badge">{a.suite}</div>

          {a.summary && <p class="analysis-summary">{a.summary}</p>}

          {a.strengths?.length > 0 && (
            <div class="analysis-group">
              <h3 class="analysis-group-title">Strengths</h3>
              <ul class="insight-list strength-list">
                {a.strengths.map(s => (
                  <li><strong>{s.title}</strong> — {s.detail}</li>
                ))}
              </ul>
            </div>
          )}

          {a.critical_gaps?.length > 0 && (
            <div class="analysis-group">
              <h3 class="analysis-group-title">Critical Gaps</h3>
              <ul class="insight-list gap-list">
                {a.critical_gaps.map(g => (
                  <li>
                    <strong>{g.title}</strong> — {g.detail}
                    {g.evidence && <span class="gap-evidence"> ({g.evidence})</span>}
                  </li>
                ))}
              </ul>
            </div>
          )}

          {a.action_plan?.length > 0 && (
            <div class="analysis-group">
              <h3 class="analysis-group-title">Action Plan</h3>
              <div class="action-cards">
                {a.action_plan.map(action => (
                  <div class="action-card">
                    <div class="action-header">
                      <span class="action-priority">#{action.priority}</span>
                      <span class="action-title">{action.title}</span>
                      <span class={`action-badge impact-${action.impact}`}>{action.impact} impact</span>
                      <span class={`action-badge effort-${action.effort}`}>{action.effort} effort</span>
                    </div>
                    <p class="action-desc">{action.description}</p>
                    {action.implementation && (
                      <div class="action-impl">
                        <span class="action-impl-label">Implementation:</span> {action.implementation}
                      </div>
                    )}
                    {action.success_metric && (
                      <div class="action-metric">
                        <span class="action-metric-label">Success:</span> {action.success_metric}
                      </div>
                    )}
                  </div>
                ))}
              </div>
            </div>
          )}

          {a.notes_on_previous && (
            <div class="analysis-group">
              <h3 class="analysis-group-title">Notes on Previous Attempts</h3>
              <p class="notes-on-prev">{a.notes_on_previous}</p>
            </div>
          )}
        </div>
      ))}
    </section>
  )}

  <!-- ═══ SEARCH TUNING PARAMETERS ═══ -->
  <section class="tuning-section">
    <h2>Search Tuning Parameters</h2>
    <p class="tuning-intro">
      These are the primary knobs controlling retrieval, ranking, and authority weighting.
      Changing any of these affects scores without requiring a reindex.
    </p>

    <div class="tuning-grid">
      <div class="tuning-group">
        <h3 class="tuning-group-title">Retrieval (Meilisearch)</h3>
        <table class="tuning-table">
          <thead><tr><th>Parameter</th><th>Value</th><th>Env var</th><th>Effect</th></tr></thead>
          <tbody>
            <tr>
              <td><code>semanticRatio</code></td>
              <td class="val">0.5</td>
              <td>—</td>
              <td>Blend of BM25 keyword (0) vs. 512-dim semantic (1). 0.5 = equal weight.</td>
            </tr>
            <tr>
              <td><code>overFetch multiplier</code></td>
              <td class="val">20×</td>
              <td><code>AUTHORITY_RERANK_MULTIPLIER</code></td>
              <td>Fetch this many × limit before reranking so high-authority hits outside top N can surface.</td>
            </tr>
            <tr>
              <td><code>TOP_K</code></td>
              <td class="val">10</td>
              <td>—</td>
              <td>Results returned to caller. Battery tests pass/fail within this window.</td>
            </tr>
          </tbody>
        </table>
      </div>

      <div class="tuning-group">
        <h3 class="tuning-group-title">Authority Scoring</h3>
        <p class="tuning-formula"><code>score = relevance × olMultiplier × (1 + boost × (authority − 5) / 5)</code></p>
        <table class="tuning-table">
          <thead><tr><th>Parameter</th><th>Value</th><th>Env var</th><th>Effect</th></tr></thead>
          <tbody>
            <tr>
              <td><code>authorityBoost</code></td>
              <td class="val">2.0</td>
              <td><code>AUTHORITY_BOOST</code></td>
              <td>Weight of authority in final score. auth=10 gets a 3× multiplier; auth=1 gets 0.4×. Needed ≥1.44 to overcome HyPE commentary advantage.</td>
            </tr>
            <tr>
              <td><code>olSourceMultiplier</code></td>
              <td class="val">2.0×</td>
              <td><code>OL_SOURCE_MULTIPLIER</code></td>
              <td>OceanLibrary hits multiply score by 2×. Compensates for archaic language scoring lower in BM25 vs. modern translations.</td>
            </tr>
          </tbody>
        </table>
      </div>

      <div class="tuning-group">
        <h3 class="tuning-group-title">Multi-Index RRF Fusion</h3>
        <p class="tuning-formula">RRF score = Σ weight / (K + rank) across indexes</p>
        <table class="tuning-table">
          <thead><tr><th>Index</th><th>Weight</th><th>Description</th></tr></thead>
          <tbody>
            <tr><td>paragraphs (main)</td><td class="val">1.0</td><td>Primary text+context hybrid search. Base signal.</td></tr>
            <tr><td>HyPE questions</td><td class="val">1.5</td><td>Hypothetical question match — highest signal when queries are question-like. Boosts relevant doc sections above pure keyword rank.</td></tr>
            <tr><td>entity mentions</td><td class="val">1.0</td><td>Named-entity sidecar. Active when resolved entity IDs are present (entity-aware search).</td></tr>
            <tr><td>RRF K constant</td><td class="val">60</td><td>Rank fusion smoothing. Higher = flatter curve, less winner-take-all.</td></tr>
          </tbody>
        </table>
      </div>

      <div class="tuning-group">
        <h3 class="tuning-group-title">Authority Tiers</h3>
        <p class="tuning-note">Scores 0–10 set per document in <code>api/lib/authority.js</code>. Same author in different container types → different authority (e.g. primary scripture vs. extracted quote in secondary source).</p>
        <table class="tuning-table">
          <thead><tr><th>Score</th><th>Source type</th><th>Examples</th></tr></thead>
          <tbody>
            <tr><td class="val auth-10">10</td><td>Primary scripture</td><td>Quran, Bible, Aqdas, Hidden Words, Bhagavad Gita, Analects</td></tr>
            <tr><td class="val auth-high">8–9</td><td>Core canonical writings</td><td>Shoghi Effendi letters, ʿAbdu'l-Bahá talks &amp; tablets, Iqán</td></tr>
            <tr><td class="val auth-mid">5–7</td><td>Authoritative secondary</td><td>UHJ letters, approved histories, classic commentaries</td></tr>
            <tr><td class="val auth-low">1–4</td><td>Supplemental / general</td><td>Modern scholarship, devotional works, encyclopedias</td></tr>
            <tr><td class="val auth-quote">−0.5</td><td>Extracted quote penalty</td><td>Baha'u'llah quoted in Shoghi Effendi = 9.5 (not 10) — canonical source wins when indexed</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ═══ HOW TO RUN ═══ -->
  <section>
    <h2>Running the Battery</h2>
    <div class="code-block">
      <pre><code># Unified suite (504 fixtures)
node tests/quality/score-search.mjs --write-report

# With AI analysis
node tests/quality/score-search.mjs --write-report --analyze

# Single category
node tests/quality/score-search.mjs --category=phrase-match</code></pre>
    </div>
    <p class="run-note">
      Writes <code>tests/quality/results-latest.json</code>. Commit the file to update this page.
      The <code>--analyze</code> flag calls <code>claude-opus-4-7</code> to generate the improvement strategy.
      See <a href="/docs/ocean-search-testing">the scoring model guide</a> for details on how results are evaluated.
    </p>
  </section>

</DocsLayout>

<style>
  .subtitle {
    font-size: 1.05rem;
    color: var(--text-secondary);
    margin: 0.25rem 0 2rem;
    max-width: 72ch;
  }

  /* ── Gauge sections ── */
  .gauge-section {
    background: var(--surface-2);
    border: 1px solid var(--border-subtle);
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
    margin-bottom: 1rem;
  }

  .gauge-header {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }
  .suite-label { font-weight: 700; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-secondary); }
  .suite-count { font-size: 0.8rem; color: var(--text-muted); }
  .suite-note { font-size: 0.72rem; color: var(--text-muted); font-style: italic; }
  .suite-date { font-size: 0.75rem; color: var(--text-muted); margin-left: auto; }

  /* ── Metrics guide ── */
  .metrics-guide {
    background: var(--surface-2);
    border: 1px solid var(--border-subtle);
    border-radius: 10px;
    padding: 0.9rem 1.25rem;
    margin-bottom: 1.5rem;
    max-width: 72ch;
  }
  .metrics-guide-title {
    font-size: 0.75rem;
    font-weight: 700;
