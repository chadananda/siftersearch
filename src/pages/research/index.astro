---
// Deep Research index — live listing from API.
// SEO-optimized index of all completed interfaith research topics.
import Layout from '../../layouts/Layout.astro';
import LiquidBackground from '../../components/LiquidBackground.svelte';
import NavBar from '../../components/common/NavBar.svelte';

const API_BASE = import.meta.env.PUBLIC_API_URL || 'https://api.siftersearch.com';
const res = await fetch(`${API_BASE}/api/v1/deep-research?status=complete&limit=100`);
const { records = [] } = res.ok ? await res.json() : {};

const items = records.map(r => ({
  ...r,
  topic_tags: r.topic_tags ? (typeof r.topic_tags === 'string' ? JSON.parse(r.topic_tags) : r.topic_tags) : [],
  traditions: r.traditions_covered ? r.traditions_covered.split(',').filter(Boolean) : [],
}));

const TOPIC_LABELS: Record<string, string> = {
  'theodicy': 'Theodicy',
  'tests-trials': 'Tests & Trials',
  'afterlife': 'Afterlife',
  'prayer': 'Prayer',
  'soul-spirit': 'Soul & Spirit',
  'mysticism': 'Mysticism',
  'ethics': 'Ethics',
  'justice': 'Justice',
  'mercy-compassion': 'Mercy',
  'free-will': 'Free Will',
  'revelation': 'Revelation',
  'progressive-revelation': 'Progressive Revelation',
  'science-reason': 'Science & Reason',
  'unity': 'Unity',
  'equality': 'Equality',
  'authority': 'Authority',
  'law-practice': 'Law & Practice',
  'eschatology': 'Eschatology',
  'social-order': 'Social Order',
  'death-grief': 'Death & Grief',
  'love': 'Love',
  'scripture-study': 'Scripture',
  'creation': 'Creation',
  'sin-redemption': 'Sin & Redemption',
  'community': 'Community',
};

const TRADITION_COLORS: Record<string, string> = {
  "Baha'i": '#c8a44a', 'Islam': '#2e7d32', 'Christianity': '#1565c0',
  'Judaism': '#6a1b9a', 'Buddhism': '#f57f17', 'Hinduism': '#bf360c',
  'Taoism': '#00695c', 'Sikhism': '#ad1457', 'Zoroastrian': '#e65100',
};

// Unique topics in order of first appearance
const topicOrder = [...new Set(items.map(i => i.topic_tags[0]).filter(Boolean))];
const totalPassages = items.reduce((s, i) => s + (i.total_selected || 0), 0);
const totalTraditions = [...new Set(items.flatMap(i => i.traditions))].length;

const description = `${items.length} deep research topics across ${totalTraditions} traditions — scripture, theology, and mystical writings curated for depth and accuracy.`;

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Deep Research — SifterSearch Interfaith Library",
  "description": description,
  "url": "https://siftersearch.com/research",
  "publisher": { "@type": "Organization", "name": "SifterSearch", "url": "https://siftersearch.com" },
  "hasPart": items.slice(0, 20).map(r => ({
    "@type": "Article",
    "name": r.canonical_question,
    "url": `https://siftersearch.com/research/${r.slug}`,
  })),
};
---

<Layout
  title="Interfaith Deep Research — SifterSearch"
  description={description}
  image="/og-research.png"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    <link rel="canonical" href="https://siftersearch.com/research" />
  </Fragment>

  <LiquidBackground client:only="svelte" />
  <NavBar currentPage="research" client:load />

  <main class="research-index">

    <!-- Hero -->
    <header class="research-hero">
      <div class="hero-inner">
        <div class="hero-eyebrow">Interfaith Deep Research</div>
        <h1>Questions that span traditions</h1>
        <p class="hero-sub">Scripture, theology, and mystical writings from the world's great religions — curated by question, compared by tradition.</p>
        <div class="hero-stats">
          <div class="stat-item"><strong>{items.length}</strong><span>topics</span></div>
          <div class="stat-div" />
          <div class="stat-item"><strong>{totalTraditions}</strong><span>traditions</span></div>
          <div class="stat-div" />
          <div class="stat-item"><strong>{totalPassages.toLocaleString()}</strong><span>passages</span></div>
        </div>
      </div>
    </header>

    <!-- Filter bar -->
    <div class="filter-bar" id="filter-bar">
      <div class="filter-inner">
        <button class="filter-pill active" data-filter="all">All Topics</button>
        {topicOrder.map(key => (
          <button class="filter-pill" data-filter={key}>
            {TOPIC_LABELS[key] || key}
          </button>
        ))}
      </div>
    </div>

    <!-- Article grid -->
    <div class="grid-wrap">
      <div class="article-grid" id="article-grid">
        {items.map(item => {
          const topic = item.topic_tags[0] || 'general';
          return (
            <a
              href={`/research/${item.slug}`}
              class="article-card"
              data-topic={topic}
            >
              {item.hero_image ? (
                <div class="card-img-wrap">
                  <img src={item.hero_image} alt="" loading="lazy" class="card-img" />
                  <div class="card-img-overlay" />
                  <span class="card-topic-chip">{TOPIC_LABELS[topic] || topic}</span>
                </div>
              ) : (
                <div class="card-no-img">
                  <span class="card-topic-chip-plain">{TOPIC_LABELS[topic] || topic}</span>
                </div>
              )}
              <div class="card-body">
                <p class="card-question">{item.canonical_question}</p>
                <div class="card-foot">
                  <div class="traditions-row">
                    {item.traditions.slice(0, 6).map(t => (
                      <span class="trad-dot" style={`background:${TRADITION_COLORS[t] || '#888'}`} title={t} />
                    ))}
                    {item.traditions.length > 6 && <span class="trad-more">+{item.traditions.length - 6}</span>}
                  </div>
                  <span class="card-count">{item.total_selected || 0} passages</span>
                </div>
              </div>
            </a>
          );
        })}

        {items.length === 0 && (
          <div class="empty-state">
            <p>No completed research yet. Ask Jafar a question to begin.</p>
            <a href="/" class="btn-primary">Start a conversation →</a>
          </div>
        )}
      </div>

      <!-- No results message (hidden by default) -->
      <p class="no-results" id="no-results" style="display:none">No topics match this filter.</p>
    </div>

    <!-- CTA -->
    <section class="index-cta">
      <div class="cta-inner">
        <h2>Don't see your question?</h2>
        <p>Ask Jafar — deep research is queued automatically for substantial interfaith questions.</p>
        <a href="/" class="btn-primary">Ask Jafar →</a>
      </div>
    </section>

  </main>
</Layout>

<script>
  const pills = document.querySelectorAll<HTMLButtonElement>('.filter-pill');
  const cards = document.querySelectorAll<HTMLElement>('.article-card');
  const noResults = document.getElementById('no-results');

  pills.forEach(pill => {
    pill.addEventListener('click', () => {
      const filter = pill.dataset.filter!;
      pills.forEach(p => p.classList.remove('active'));
      pill.classList.add('active');
      let visible = 0;
      cards.forEach(card => {
        const show = filter === 'all' || card.dataset.topic === filter;
        card.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      if (noResults) noResults.style.display = visible === 0 ? 'block' : 'none';
    });
  });
</script>

<style>
  .research-index { min-height: 100vh; padding-bottom: 4rem; }

  /* ── Hero ── */
  .research-hero {
    padding: 4.5rem 1.5rem 2.5rem;
    text-align: center;
  }
  .hero-inner { max-width: 680px; margin: 0 auto; }
  .hero-eyebrow {
    display: inline-block; font-size: 0.68rem; font-weight: 700;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--accent); border: 1px solid var(--accent);
    border-radius: 4px; padding: 0.18rem 0.55rem; margin-bottom: 1rem;
  }
  h1 {
    font-size: clamp(1.75rem, 4.5vw, 2.75rem); font-weight: 700;
    color: var(--text-primary); margin: 0 0 0.875rem; line-height: 1.2;
  }
  .hero-sub {
    font-size: 1rem; color: var(--text-secondary); line-height: 1.7;
    margin: 0 0 1.75rem;
  }
  .hero-stats {
    display: flex; align-items: center; justify-content: center;
    gap: 1.25rem; flex-wrap: wrap;
  }
  .stat-item { display: flex; flex-direction: column; align-items: center; gap: 0.1rem; }
  .stat-item strong { font-size: 1.5rem; font-weight: 700; color: var(--text-primary); line-height: 1; }
  .stat-item span { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); }
  .stat-div { width: 1px; height: 2rem; background: var(--border-subtle); }

  /* ── Filter bar ── */
  .filter-bar {
    border-top: 1px solid var(--border-subtle);
    border-bottom: 1px solid var(--border-subtle);
    background: var(--surface-1);
    padding: 0.6rem 1.5rem;
    position: sticky; top: 0; z-index: 10;
  }
  .filter-inner {
    max-width: 1200px; margin: 0 auto;
    display: flex; gap: 0.4rem; flex-wrap: wrap; align-items: center;
  }
  .filter-pill {
    padding: 0.28rem 0.75rem; border-radius: 20px;
    font-size: 0.75rem; font-weight: 500; cursor: pointer;
    border: 1px solid var(--border-subtle); background: transparent;
    color: var(--text-secondary); transition: all 0.15s;
    white-space: nowrap;
  }
  .filter-pill:hover { border-color: var(--accent); color: var(--accent); }
  .filter-pill.active {
    background: var(--accent); border-color: var(--accent);
    color: #fff; font-weight: 600;
  }

  /* ── Grid ── */
  .grid-wrap { max-width: 1300px; margin: 0 auto; padding: 2rem 1.5rem; }
  .article-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.1rem;
  }
  @media (max-width: 1100px) { .article-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 780px)  { .article-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 480px)  { .article-grid { grid-template-columns: 1fr; } }

  /* ── Article card ── */
  .article-card {
    display: flex; flex-direction: column;
    border-radius: 10px; overflow: hidden;
    border: 1px solid var(--border-subtle); background: var(--surface-1);
    text-decoration: none; transition: all 0.18s;
  }
  .article-card:hover {
    border-color: var(--accent); transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0,0,0,0.22);
  }

  /* Image variant */
  .card-img-wrap { position: relative; width: 100%; aspect-ratio: 4/3; overflow: hidden; flex-shrink: 0; }
  .card-img { width: 100%; height: 100%; object-fit: cover; object-position: center; display: block; transition: transform 0.35s; }
  .article-card:hover .card-img { transform: scale(1.04); }
  .card-img-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to bottom, transparent 40%, rgba(6,14,30,0.55) 100%);
    pointer-events: none;
  }
  .card-topic-chip {
    position: absolute; bottom: 0.5rem; left: 0.6rem;
    font-size: 0.62rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.08em; color: rgba(255,255,255,0.85);
    background: rgba(6,14,30,0.5); backdrop-filter: blur(4px);
    padding: 0.18rem 0.45rem; border-radius: 3px;
  }

  /* No-image variant */
  .card-no-img {
    padding: 0.75rem 0.75rem 0;
    flex-shrink: 0;
  }
  .card-topic-chip-plain {
    display: inline-block; font-size: 0.62rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.08em;
    color: var(--accent); border: 1px solid var(--accent);
    padding: 0.15rem 0.4rem; border-radius: 3px;
  }

  /* Card body */
  .card-body { display: flex; flex-direction: column; gap: 0.6rem; padding: 0.85rem; flex: 1; }
  .card-question {
    font-size: 0.875rem; font-weight: 500; line-height: 1.45;
    color: var(--text-primary); margin: 0; flex: 1;
  }
  .card-foot {
    display: flex; align-items: center;
    justify-content: space-between; gap: 0.4rem;
    margin-top: auto; padding-top: 0.4rem;
    border-top: 1px solid var(--border-subtle);
  }
  .traditions-row { display: flex; align-items: center; gap: 3px; }
  .trad-dot { width: 9px; height: 9px; border-radius: 50%; display: inline-block; }
  .trad-more { font-size: 0.65rem; color: var(--text-muted); }
  .card-count { font-size: 0.7rem; color: var(--text-muted); white-space: nowrap; }

  /* ── Misc ── */
  .no-results { text-align: center; padding: 3rem; color: var(--text-muted); }
  .empty-state { grid-column: 1/-1; text-align: center; padding: 4rem 1.5rem; color: var(--text-muted); }

  .index-cta { max-width: 560px; margin: 0 auto; text-align: center; padding: 2rem 1.5rem 1rem; }
  .index-cta h2 { font-size: 1.3rem; margin: 0 0 0.6rem; color: var(--text-primary); }
  .index-cta p { color: var(--text-secondary); margin: 0 0 1.25rem; line-height: 1.7; font-size: 0.93rem; }

  .btn-primary {
    display: inline-block; padding: 0.6rem 1.4rem; border-radius: 8px;
    background: var(--accent); color: #fff; font-weight: 600;
    text-decoration: none; transition: background 0.15s;
  }
  .btn-primary:hover { background: var(--accent-hover); }
</style>
