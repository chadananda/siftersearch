---
// Prerendered (SSG) at build time: the cast data is baked in so the page paints instantly with static cards
// + CSS animations; the search/filter island hydrates passively (client:idle). Rebuild to refresh the data.
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import NavBar from '../components/common/NavBar.svelte';
import BiographyBrowser from '../components/BiographyBrowser.svelte';

// Prerender MUST bake the cast data so the static page paints full content (cards + hero) — the island then
// hydrates interactivity onto that existing DOM. Never ship an empty shell that fills in client-side: retry,
// and fail the build rather than deploy a page that reflows content in on load.
// Proof of concept: the page is built entirely on the official public API (/api/v1/people …), the same
// endpoints any third-party consumer would use — not the internal /api/graph/bio/* routes.
const API = import.meta.env.PUBLIC_API_URL || 'https://api.siftersearch.com';
// The full cast (~600 people, ~440KB) is a heavy query — ~9s warm, and slower when tower-nas is also grounding.
// Retry patiently with backoff (generous timeout) so a transient blip under load doesn't fail the build, but still
// REFUSE to ship an empty page (baked data = no reflow on load; that's the whole point of prerendering here).
let initialData = null;
for (let attempt = 0; attempt < 6 && !initialData?.people?.length; attempt++) {
  if (attempt > 0) await new Promise((r) => setTimeout(r, 3000));   // let the API/cache recover between tries
  try {
    const res = await fetch(`${API}/api/v1/people?limit=2000`, { signal: AbortSignal.timeout(45000) });
    if (res.ok) initialData = await res.json();
  } catch (e) { /* transient — retry */ }
}
if (!initialData?.people?.length) {
  throw new Error('biography prerender: /api/v1/people returned no data after 6 tries — refusing to ship an empty page (is tower-nas up?)');
}
---

<Layout
  title="Biographical Archive — SifterSearch"
  description="A searchable archive of the people of early Bábí and Bahá'í history — kings and martyrs, scholars and villagers — with portraits, relationships, and sources drawn from across the library."
>
  <NavBar client:load currentPage="biography" />
  <BiographyBrowser client:idle initialData={initialData} />
</Layout>
