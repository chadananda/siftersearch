---
// IslandSkeleton — SSR placeholder for a client island's `slot="fallback"`. Astro renders it on the server so
// the page has real content immediately; it reserves the island's layout (minHeight) so when the island hydrates
// and replaces it there is NO reflow. Props: minHeight (reserve the content area), label (a11y/status text).
const { minHeight = 'calc(100vh - 3.5rem)', label = 'Loading…' } = Astro.props;
---
<div class="island-skeleton" style={`min-height:${minHeight}`} role="status" aria-live="polite">
  <span class="island-skeleton__spinner" aria-hidden="true"></span>
  <span class="island-skeleton__label">{label}</span>
</div>
<style>
  .island-skeleton {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    color: var(--text-muted, #9ca3af);
  }
  .island-skeleton__spinner {
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 50%;
    border: 2px solid var(--border-subtle, #e5e7eb);
    border-top-color: var(--accent, var(--accent-primary, #6b7280));
    animation: island-spin 0.8s linear infinite;
  }
  .island-skeleton__label { font-size: 0.8125rem; letter-spacing: 0.01em; }
  @keyframes island-spin { to { transform: rotate(360deg); } }
  @media (prefers-reduced-motion: reduce) {
    .island-skeleton__spinner { animation: none; opacity: 0.6; }
  }
</style>
