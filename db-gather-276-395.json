  {
    "canonical_name": "Mullá Aḥmad-i-Mu‘allim",
    "entity_type": "person",
    "side": "Bábí",
    "is_new": true,
    "db_statements": ["The next to embrace the Faith among the s̱hayḵhís of Ḵhurásán was Mullá Aḥmad-i-Mu‘allim, who, while in Karbilá, had been the instructor of the children of Siyyid Káẓim."],
    "mention_idxs": [276]
  },
  {
    "canonical_name": "Mírzá Muḥammad Báqir-i-Qá’iní",
    "entity_type": "person",
    "side": "Bábí",
    "is_new": true,
    "db_statements": ["Mírzá Muḥammad Báqir-i-Qá’iní, who, for the remaining years of his life, had established his residence in Mas̱hhad, was the next to embrace the Message.", "He fell a martyr at the fort of S̱hayḵh Ṭabarsí. In his last days he was bidden by Quddús, after the tragic death of Mullá Ḥusayn, to assume the leadership of the heroic defenders of that fort."],
    "mention_idxs": [277]
  },
  {
    "canonical_name": "Ḥájí Abu'l-Ḥasan-i-S̱hírází",
    "entity_type": "person",
    "side": "Bábí",
    "is_new": true,
    "db_statements": ["I have heard Ḥájí Abu’l-Ḥasan-i-S̱hírází, who was travelling in the same vessel as the Báb, describe the circumstances of that memorable voyage.", "Ḥájí Abu’l-Ḥasan-i-Bazzáz, who, as a fellow-traveller of the Báb during His pilgrimage to Ḥijáz, had but dimly recognised the overpowering majesty of His Mission, was, on that memorable Friday, profoundly shaken and completely transformed."],
    "mention_idxs": [286, 325]
  },
  {
    "canonical_name": "Mírzá Abu’l-Qásim, the Imám-Jum‘ih of Ṭihrán",
    "entity_type": "person",
    "side": "",
    "is_new": true,
    "db_statements": ["S̱hayḵh Abú-Turáb... bore a striking resemblance to the character of the late Mírzá Abu’l-Qásim, the Imám-Jum‘ih of Ṭihrán."],
    "mention_idxs": [318]
  },
